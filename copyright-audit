                    yes_mode = True
            except OSError:
                pass

    # ══════════════════════════════════════════════════════════════════
    # Interactive fix mode
    # ══════════════════════════════════════════════════════════════════
    if fix_mode and has_fixable and copyright_file:
        print("=" * W)
        print("INTERACTIVE FIX MODE")
        print("=" * W)
        print()
        print("  (In each prompt: A = yes to all remaining  |  X = no to all remaining)\n")

        # input() won't work — stdin is the heredoc.
        # Read interactive answers from /dev/tty instead.
        import atexit
        try:
            _tty = open("/dev/tty", "r")
            atexit.register(_tty.close)
        except OSError:
            print("ERROR: Cannot open /dev/tty for interactive input.", file=sys.stderr)
            print("  --fix requires an interactive terminal.", file=sys.stderr)
            sys.exit(1)

        # Force unbuffered output so prompts appear immediately
        import functools
        print = functools.partial(print, flush=True)

        _batch_ans = [None]  # None = no all-choice; True = yes-to-all; False = no-to-all

        def ask(prompt, batch=False):
            """Prompt the user and read from /dev/tty.

            When batch=True, the response 'A' sets yes-to-all for all future
            batch prompts, and 'X' sets no-to-all.
            """
            if yes_mode:
                sys.stdout.write(prompt + "y (--yes)\n")
                sys.stdout.flush()
                return "y"
            if batch:
                if _batch_ans[0] is True:
                    sys.stdout.write(prompt + "y (yes to all)\n")
                    sys.stdout.flush()
                    return "y"
                if _batch_ans[0] is False:
                    sys.stdout.write(prompt + "n (no to all)\n")
                    sys.stdout.flush()
                    return "n"
            sys.stdout.write(prompt)
            sys.stdout.flush()
            try:
                ans = _tty.readline().rstrip("\n")
            except EOFError:
                return ""
            if batch:
                al = ans.strip().lower()
                if al in ("a", "all"):
                    _batch_ans[0] = True
                    return "y"
                if al in ("x", "none"):
                    _batch_ans[0] = False
                    return "n"
            return ans

        # Read the current copyright file
        with open(copyright_file, encoding="utf-8") as f:
            original_text = f.read()
        working_text = original_text
        changes_made = 0

        # Helper: build compact globs from a list of file paths
        def make_fix_globs(paths, no_glob_dirs=frozenset()):
            """Group files by directory and produce compact globs.
            Uses dir/* only when multiple files share a directory.
            Directories in no_glob_dirs are always listed individually."""
            dirs = defaultdict(list)
            for p in paths:
                p = p.lstrip("./")
                d = str(Path(p).parent)
                dirs[d].append(p)
            globs = []
            for d, files in sorted(dirs.items()):
                if d == ".":
                    globs.extend(sorted(files))
                elif len(files) > 1 and d not in no_glob_dirs:
                    globs.append(d + "/*")
                else:
                    globs.extend(sorted(files))
            return globs

        # Helper: find the copyright holders for a set of files from scan
        def get_copyrights_for_files(filepaths):
            cops = set()
            fp_set = set(filepaths)
            for r in scan_results:
                if r["path"] in fp_set or r["path"].lstrip("./") in fp_set:
                    for c in r.get("copyrights", []):
                        if c:
                            cops.add(c)
            return sorted(cops)

        # Helper: find insertion point (before the first standalone License: block)
        def find_stanza_insert_pos(text):
            """Find the byte offset to insert new File stanzas.
            Inserts before the first standalone License: paragraph."""
            best_pos = len(text)  # default: end of file
            for m in re.finditer(r'\n\nLicense: ', text):
                # Check this is standalone (no Files: in this paragraph)
                para_start = m.start() + 2
                para_end = text.find("\n\n", para_start)
                if para_end == -1:
                    para_end = len(text)
                para = text[para_start:para_end]
                if not para.startswith("Files:") and "\nFiles:" not in para:
                    best_pos = m.start() + 1  # after the first \n
                    break
            return best_pos

        # ── Fix 0: DEP-5 format fixes ───────────────────────────────
        fixable_dep5 = [i for i in dep5_issues if i[3] is not None]
        if fixable_dep5:
            print(f"{len(fixable_dep5)} auto-fixable DEP-5 format issue(s):\n")
            for lnum, sev, msg, fix_tag in fixable_dep5:
                prefix = f"Line {lnum}: " if lnum > 0 else ""
                print(f"  [{sev.upper()}] {prefix}{msg}")

            answer = ask("\n  Apply DEP-5 format fixes? [y/N/A/X] ", batch=True).strip().lower()
            if answer in ("y", "yes"):
                working_text, fix_descs = fix_dep5_format(working_text)
                for desc in fix_descs:
                    print(f"  ✓ {desc}")
                changes_made += 1
                print()
            else:
                print("  ✗ Skipped.\n")

        # ── Fix 1: Add stanzas for mismatched files ──────────────────
        if real_mismatches:
            # Group mismatched files by detected license, skipping
            # debian/*, symlinks, metadata/infrastructure files
            # (the latter are covered by the Files: * catch-all),
            # and files already covered by a specific (non-catch-all)
            # stanza — those already have an intentional declaration.
            def _has_specific_stanza(filepath):
                """True if filepath matches any existing stanza glob other
                than the '*' catch-all.  Such files should not get a
                duplicate stanza; the existing declaration is intentional."""
                fp = filepath.lstrip("./")
                for glob_pat, _ in stanzas:
                    if glob_pat == "*":
                        continue
                    if fnmatch.fnmatch(fp, glob_pat) or fp == glob_pat:
                        return True
                return False

            by_license = defaultdict(list)
            for (det, decl), files in real_mismatches.items():
                filtered = [f for f in files
                            if not f.lstrip("./").startswith("debian/")
                            and not os.path.islink(f.lstrip("./"))
                            and not is_metadata_file(f)
                            and not _has_specific_stanza(f)]
                if filtered:
                    by_license[det].extend(filtered)

            # ── Group by (license, per-file copyright holders) ────────
            # Instead of broad dir/* globs that lump unrelated holders,
            # produce per-author stanzas.  Files with the same author(s)
            # and license share a single stanza.

            def _holder_key(cop):
                """Normalize a copyright string to an author identity key."""
                s = cop.strip()
                s = re.sub(r'^(?:Copyright\s+)?(?:\(c\)\s+)?', '', s, flags=re.I)
                s = re.sub(r'^[\d,\s-]+', '', s).strip()
                s = re.sub(r'\s*<[^>]*>', '', s)   # strip email
                s = re.sub(r'[\s\-]+', '', s)      # collapse spaces/hyphens
                return s.lower()

            author_groups = defaultdict(lambda: {"files": [], "cops": []})
            for det_lic, files in by_license.items():
                for f in files:
                    fps = {f, f.lstrip("./")}
                    file_cops = []
                    for r in scan_results:
                        if r["path"] in fps or r["path"].lstrip("./") in fps:
                            file_cops = [c for c in r.get("copyrights", []) if c]
                            break
                    ak = frozenset(_holder_key(c) for c in file_cops)
                    key = (det_lic, ak)
                    author_groups[key]["files"].append(f)
                    author_groups[key]["cops"].extend(file_cops)

            if author_groups:
                print("The following new Files: stanzas are proposed for")
                print("files whose detected license differs from what's declared:\n")

            for (det_lic, _ak), grp in sorted(
                    author_groups.items(),
                    key=lambda kv: (kv[0][0], sorted(f.lstrip("./") for f in kv[1]["files"])[0])):
                files = grp["files"]
                cops_raw = sorted(set(grp["cops"]))
                merged_cops = merge_copyrights(cops_raw, file_paths=files)
                cop_field = format_copyright_field(merged_cops)
                # Apply glob simplification to file list
                # Build directory file counts from all stanzas so
                # dir/* is only used when this stanza owns all files
                # in the directory.
                _fix1_dir_counts = defaultdict(int)
                for _sg, _sl in stanzas:
                    if _sg == "*" or "*" in _sg:
                        continue
                    _sd = str(Path(_sg).parent)
                    _fix1_dir_counts[_sd] += 1
                globs = _simplify_file_list(
                    sorted(f.lstrip("./") for f in files),
                    all_dir_counts=_fix1_dir_counts)

                print(f"  Proposed stanza ({len(files)} file(s)):")
                print(f"  ┌──────────────────────────────────────")
                if len(globs) <= 3:
                    print(f"  │ Files: {globs[0]}")
                    for g in globs[1:]:
                        print(f"  │        {g}")
                else:
                    print(f"  │ Files: {globs[0]}")
                    print(f"  │        {globs[1]}")
                    print(f"  │        ... ({len(globs)} globs total)")
                for i, cl in enumerate(merged_cops or ["FIXME"]):
                    tag = "Copyright" if i == 0 else "          "
                    print(f"  │ {tag}: {cl}")
                print(f"  │ License: {det_lic}")
                print(f"  └──────────────────────────────────────")

                answer = ask("  Add this stanza? [y/N/e(dit)/A/X] ", batch=True).strip().lower()

                if answer in ("y", "yes"):
                    # Build the stanza text
                    files_str = format_files_field(globs)
                    stanza = f"\n{files_str}\nCopyright: {cop_field}\nLicense: {det_lic}\n"
                    pos = find_stanza_insert_pos(working_text)
                    working_text = working_text[:pos] + stanza + working_text[pos:]
                    changes_made += 1
                    print(f"  ✓ Added.\n")
                elif answer in ("e", "edit"):
                    print("  Edit copyright holders (one per line, blank to finish):")
                    edited_cops = []
                    for cl in merged_cops:
                        new_cl = ask(f"    [{cl}]: ").strip()
                        edited_cops.append(new_cl if new_cl else cl)
                    extra = ask("    [add more?]: ").strip()
                    while extra:
                        edited_cops.append(extra)
                        extra = ask("    [add more?]: ").strip()
                    cop_field = format_copyright_field(edited_cops if edited_cops else merged_cops)
                    print(f"  Enter license (or press Enter for '{det_lic}'):")
                    new_lic = ask("    License: ").strip()
                    if not new_lic:
                        new_lic = det_lic
                    files_str = format_files_field(globs)
                    stanza = f"\n{files_str}\nCopyright: {cop_field}\nLicense: {new_lic}\n"
                    pos = find_stanza_insert_pos(working_text)
                    working_text = working_text[:pos] + stanza + working_text[pos:]
                    changes_made += 1
                    print(f"  ✓ Added (edited).\n")
                else:
                    print(f"  ✗ Skipped.\n")

        # ── Fix 2: Remove stale globs ────────────────────────────────
        if stale:
            print(f"{len(stale)} stale glob(s) found that match no file:\n")
            for glob_pat, lic in stale:
                print(f"  Stale: {glob_pat}  (License: {lic})")
            answer = ask("\n  Remove all stale globs? [y/N/A/X] ", batch=True).strip().lower()
            if answer in ("y", "yes"):
                for glob_pat, lic in stale:
                    escaped = re.escape(glob_pat)
                    # 1) Remove glob if it's the only entry on a continuation line
                    working_text = re.sub(
                        r'\n +' + escaped + r' *(?=\n)', '', working_text)
                    # 2) Remove glob when sharing a line with other globs
                    #    (on Files: line or continuation — just drop the token)
                    working_text = re.sub(
                        r'(?<= )' + escaped + r'(?= |\n)', '', working_text)
                    # 3) Clean up any double-spaces left by token removal
                    working_text = re.sub(r'(Files: ) +', r'\1', working_text)
                    working_text = re.sub(r'(?<=\n) {8,}(?=\S)', '       ', working_text)
                    # 4) If Files: line is now empty, remove the entire stanza
                    working_text = re.sub(
                        r'\nFiles: *\n'
                        r'Copyright:[^\n]*(?:\n +[^\n]+)*\n'
                        r'License:[^\n]*(?:\n .*)*',
                        '', working_text)
                    # 5) If glob was the sole entry, remove the entire stanza
                    working_text = re.sub(
                        r'\nFiles: ' + escaped + r'\n'
                        r'Copyright:[^\n]*(?:\n +[^\n]+)*\n'
                        r'License:[^\n]*(?:\n .*)*',
                        '', working_text)
                changes_made += 1
                print("  ✓ Removed.\n")
            else:
                print("  ✗ Skipped.\n")

        # ── Fix 3: Add missing license text blocks ───────────────────
        # Check if any new licenses were introduced that lack a text block
        new_lics_in_text = set()
        for m in re.finditer(r'^License: (\S+)', working_text, re.MULTILINE):
            new_lics_in_text.add(m.group(1))

        # Licenses that appear in Files stanzas but have no standalone block
        existing_blocks = set()
        for para in working_text.split("\n\n"):
            lines = para.strip().split("\n")
            if not lines:
                continue
            first = lines[0]
            has_files = any(l.strip().startswith("Files:") for l in lines)
            if first.startswith("License:") and not has_files:
                lic_name = first[8:].strip().split()[0] if first[8:].strip() else None
                if lic_name:
                    existing_blocks.add(lic_name)

        # Collect licenses used in file stanzas
        stanza_lics = set()
        for para in working_text.split("\n\n"):
            lines = para.strip().split("\n")
            has_files = any(l.strip().startswith("Files:") for l in lines)
            if has_files:
                for l in lines:
                    if l.startswith("License:"):
                        lic = l[8:].strip().split()[0] if l[8:].strip() else None
                        if lic:
                            stanza_lics.add(lic)

        missing_blocks = stanza_lics - existing_blocks

        COMMON_LICENSES = {
            "GPL-1", "GPL-1+", "GPL-2", "GPL-2+", "GPL-3", "GPL-3+",
            "LGPL-2", "LGPL-2+", "LGPL-2.1", "LGPL-2.1+", "LGPL-3", "LGPL-3+",
            "AGPL-3", "AGPL-3+",
            "Apache-2.0", "MPL-1.1", "MPL-2.0",
            "GFDL", "GFDL-1.1", "GFDL-1.1+", "GFDL-1.2", "GFDL-1.2+", "GFDL-1.3", "GFDL-1.3+",
            "Artistic", "BSD", "CC0-1.0",
        }

        if missing_blocks:
            print(f"{len(missing_blocks)} license(s) need a License text block:\n")
            for lic in sorted(missing_blocks):
                slug = lic.rstrip("+")
                if slug in SYSTEM_COMMON_LICENSES or lic in COMMON_LICENSES:
