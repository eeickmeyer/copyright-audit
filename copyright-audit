# Desktop wallpaper metadata enrichment
# ══════════════════════════════════════════════════════════════════════
# KDE metadata.json and GNOME background-properties .xml files describe
# wallpaper images but are NOT themselves subject to the image copyright.
# Extract author/license info and apply it to the ACTUAL IMAGE FILES.

# Build path → scan_result lookup for fast enrichment
_path_to_result = {}
for _r in scan_results:
    _path_to_result[_r["path"].lstrip("./")] = _r

_enriched_count = 0

# ── KDE metadata.json enrichment ─────────────────────────────────────
for _r in scan_results:
    _fp = _r["path"].lstrip("./")
    if os.path.basename(_fp) != "metadata.json":
        continue
    try:
        with open(_fp, encoding="utf-8") as _mf:
            _meta = json.load(_mf)
    except (OSError, json.JSONDecodeError, UnicodeDecodeError):
        continue
    _kp = _meta.get("KPlugin", {})
    if not _kp:
        continue
    # Extract author holder strings
    _holders = []
    for _auth in _kp.get("Authors", []):
        _name = _auth.get("Name", "").strip()
        _email = _auth.get("Email", "").strip()
        if _name or _email:
            parts = []
            if _name:
                parts.append(_name)
            if _email:
                parts.append(f"<{_email}>")
            _holders.append(" ".join(parts))
    # Extract license
    _klic = _kp.get("License", "").strip()
    _dep5_lic = to_dep5(_klic) if _klic else None

    # Detect Unsplash-sourced images: if the metadata contains an
    # unsplash.com URL (in Website, Id, or anywhere in the JSON),
    # the actual license for the image is the Unsplash license,
    # regardless of what KPlugin.License says (it is often wrong
    # or generic for Unsplash-sourced wallpapers).
    _meta_str = json.dumps(_meta).lower()
    if "unsplash.com" in _meta_str:
        _dep5_lic = "Unsplash"

    if not _holders and not _dep5_lic:
        continue
    # Resolve symlinks in contents/images/ to find the actual image
    _wdir = str(Path(_fp).parent)
    _img_dir = os.path.join(_wdir, "contents", "images")
    if not os.path.isdir(_img_dir):
        continue
    _target_paths = set()
    for _link in os.listdir(_img_dir):
        _link_path = os.path.join(_img_dir, _link)
        if os.path.islink(_link_path):
            _real = os.path.relpath(os.path.realpath(_link_path))
            _target_paths.add(_real)
    # Enrich the actual image file entries
    for _img_path in _target_paths:
        _img_r = _path_to_result.get(_img_path)
        if not _img_r:
            continue
        for _h in _holders:
            if _h not in _img_r["copyrights"]:
                _img_r["copyrights"].append(_h)
        if _dep5_lic:
            if _img_r["licenses"] and _img_r["licenses"] != [_dep5_lic]:
                print(f"  KDE metadata override: {_img_path}: "
                      f"{', '.join(_img_r['licenses'])} → {_dep5_lic}",
                      file=sys.stderr)
            _img_r["licenses"] = [_dep5_lic]
        _enriched_count += 1

# ── SVG RDF/XML embedded metadata enrichment ─────────────────────────
# SVG files may embed Creative Commons license info and author details
# in <metadata> via RDF.  When present this is the *authoritative*
# declaration for the file and overrides scancode's heuristic detection
# (which is known to misidentify CC license versions).
_CC_URL_RE = re.compile(
    r'https?://creativecommons\.org/licenses/'
    r'([-a-z]+)/([\d.]+)',
    re.IGNORECASE,
)
_PUBLIC_DOMAIN_URLS = {
    "http://creativecommons.org/publicdomain/zero/1.0/",
    "https://creativecommons.org/publicdomain/zero/1.0/",
    "http://creativecommons.org/publicdomain/mark/1.0/",
    "https://creativecommons.org/publicdomain/mark/1.0/",
}

def _cc_url_to_dep5(url):
    """Convert a Creative Commons license URL to a DEP-5 identifier."""
    url_lower = url.lower().rstrip("/") + "/"
    if url_lower in _PUBLIC_DOMAIN_URLS:
        if "zero" in url_lower:
            return "CC0-1.0"
        return "Public-Domain"
    m = _CC_URL_RE.search(url)
    if m:
        kind = m.group(1).upper()   # e.g. "by-sa" → "BY-SA"
        ver = m.group(2)            # e.g. "4.0"
        return f"CC-{kind}-{ver}"
    return None

for _r in scan_results:
    _fp = _r["path"].lstrip("./")
    if not _fp.lower().endswith(".svg"):
        continue
    try:
        _svg_tree = ET.parse(_fp)
    except (OSError, ET.ParseError):
        continue
    _svg_root = _svg_tree.getroot()

    _svg_lic = None
    _svg_creator = None

    # Walk all elements looking for cc:license and dc:creator
    _CC_NS = "http://creativecommons.org/ns#"
    _DC_NS = "http://purl.org/dc/elements/1.1/"
    _RDF_NS = "http://www.w3.org/1999/02/22-rdf-syntax-ns#"

    for _el in _svg_root.iter():
        _tag = _el.tag
        # cc:license — the rdf:resource attribute has the license URL
        if _tag == f"{{{_CC_NS}}}license" and not _svg_lic:
            _lic_url = _el.get(f"{{{_RDF_NS}}}resource", "")
            if _lic_url:
                _svg_lic = _cc_url_to_dep5(_lic_url)
        # cc:License — rdf:about attribute has license URL (fallback)
        elif _tag == f"{{{_CC_NS}}}License" and not _svg_lic:
            _lic_url = _el.get(f"{{{_RDF_NS}}}about", "")
            if _lic_url:
                _svg_lic = _cc_url_to_dep5(_lic_url)
        # dc:creator > cc:Agent > dc:title
        elif _tag == f"{{{_DC_NS}}}creator" and not _svg_creator:
            _agent = _el.find(f"{{{_CC_NS}}}Agent")
            if _agent is not None:
                _title = _agent.find(f"{{{_DC_NS}}}title")
                if _title is not None and _title.text and _title.text.strip():
                    _svg_creator = _title.text.strip()

    if not _svg_lic and not _svg_creator:
        continue

    # License: OVERRIDE scancode's detection — the file's embedded
    # metadata is authoritative for its own license.
    if _svg_lic:
        _old_lics = _r["licenses"]
        _new_lic = to_dep5(_svg_lic)
        if _old_lics != [_new_lic]:
            _r["licenses"] = [_new_lic]
            if _old_lics:
                print(f"  SVG metadata override: {_fp}: "
                      f"{', '.join(_old_lics)} → {_new_lic}",
                      file=sys.stderr)
            _enriched_count += 1

    # Copyright holder: add if not already present
    if _svg_creator and _svg_creator not in _r["copyrights"]:
        _r["copyrights"].append(_svg_creator)
        _enriched_count += 1

# ── GNOME background-properties XML enrichment ───────────────────────
for _xml_path in globmod.glob("usr/share/gnome-background-properties/*.xml"):
    try:
        _tree = ET.parse(_xml_path)
    except (OSError, ET.ParseError):
        continue
    for _wp in _tree.findall(".//wallpaper"):
        _name_el = _wp.find("name")
        _fn_el = _wp.find("filename")
        if _name_el is None or _fn_el is None:
            continue
        _name_text = (_name_el.text or "").strip()
        _fn_text = (_fn_el.text or "").strip()
        if not _name_text or not _fn_text:
            continue
        # Extract artist from "Title by Artist Name" format
        _by_match = re.search(r'\s+by\s+(.+)$', _name_text, re.IGNORECASE)
        if not _by_match:
            continue
        _artist = _by_match.group(1).strip()
        if not _artist:
            continue
        # Map absolute filename to relative path
        _img_rel = _fn_text.lstrip("/")
        _img_r = _path_to_result.get(_img_rel)
        if not _img_r:
            continue
        if _artist not in _img_r["copyrights"]:
            _img_r["copyrights"].append(_artist)
            _enriched_count += 1
        # Detect Unsplash-sourced images: check for unsplash.com in any
        # child element (e.g. <source>) or the wallpaper XML text content
        if not _img_r["licenses"]:
            _wp_text = ET.tostring(_wp, encoding="unicode", method="text")
            _wp_xml = ET.tostring(_wp, encoding="unicode")
            if "unsplash.com" in _wp_text or "unsplash.com" in _wp_xml:
                _img_r["licenses"] = ["Unsplash"]

if _enriched_count:
    print(f"  {_enriched_count} image(s) enriched from wallpaper metadata.",
          file=sys.stderr)

# ══════════════════════════════════════════════════════════════════════
# Directory license/copyright inheritance
# ══════════════════════════════════════════════════════════════════════
# For quilt packages only: files with no detected license/copyright
# inherit from the dominant license in their directory, but ONLY when
# a COPYING or LICENSE file exists in the same or parent directory
# (indicating a subproject).  Native packages skip inheritance
# entirely — files with no detection fall through to Files: *.

_LICENSE_FILE_NAMES = {
    "copying", "copying.txt", "copying.md",
    "license", "license.txt", "license.md", "licence", "licence.txt",
    "copying.lgpl", "copying.gpl", "copying.bsd", "copying.mit",
    "copying.lib", "unlicense", "unlicense.txt",
}

_dir_lic_counts = defaultdict(lambda: defaultdict(int))
_dir_copyrights = defaultdict(set)
# Track which directories contain a COPYING/LICENSE file
_dirs_with_license_file = set()
for _r in scan_results:
    _fp = _r["path"].lstrip("./")
    _d = str(Path(_fp).parent)
    # Check if this file is a license/copying file
    if Path(_fp).name.lower() in _LICENSE_FILE_NAMES:
        _dirs_with_license_file.add(_d)
    if not _r["licenses"]:
        continue
    _lkey = tuple(sorted(set(to_dep5(l) for l in _r["licenses"])))
    _dir_lic_counts[_d][_lkey] += 1
    for _c in _r["copyrights"]:
        _dir_copyrights[_d].add(_c)

def _dir_has_license_file(d):
    """Return True if directory *d* or its parent has a COPYING/LICENSE file."""
    if d in _dirs_with_license_file:
        return True
    parent = str(Path(d).parent)
    if parent != d and parent in _dirs_with_license_file:
        return True
    return False

def dir_dominant_license(d):
    """Return the most common license tuple for directory *d*.

    Only uses licenses detected in the SAME directory."""
    if d in _dir_lic_counts and _dir_lic_counts[d]:
        return max(_dir_lic_counts[d],
                   key=_dir_lic_counts[d].get)
    return None

def dir_copyrights(d):
    """Return copyright holders from directory *d* (same-dir only)."""
    if d in _dir_copyrights and _dir_copyrights[d]:
        return sorted(_dir_copyrights[d])
    return []

_inherited_count = 0
if is_native:
    print("  Native package — skipping directory license inheritance.",
          file=sys.stderr)
else:
    for _r in scan_results:
        if _r["licenses"]:
            continue
        _fp = _r["path"].lstrip("./")
        _d = str(Path(_fp).parent)
        if not _dir_has_license_file(_d):
            continue
        _inh = dir_dominant_license(_d)
        if _inh:
            _r["licenses"] = list(_inh)
            _r["_inherited"] = True
            _inherited_count += 1
        if not _r["copyrights"]:
            _icops = dir_copyrights(_d)
            if _icops:
                _r["copyrights"] = _icops

if _inherited_count:
    print(f"  {_inherited_count} file(s) inherited license from directory context.",
          file=sys.stderr)

# ══════════════════════════════════════════════════════════════════════
# Parse existing debian/copyright
# ══════════════════════════════════════════════════════════════════════
stanzas = []  # [(glob, license_id)]
stanza_copyrights = {}  # {glob: [copyright_holder_strings]}
if copyright_file and os.path.isfile(copyright_file):
    with open(copyright_file, encoding="utf-8") as f:
        copyright_text = f.read()
    for para in copyright_text.split("\n\n"):
        files = []
        lic = None
        cops = []
        current_field = None  # Track which field continuation lines belong to
        for line in para.split("\n"):
            if line.startswith("Files:"):
                rest = line[6:].strip()
                if rest:
                    files.extend(rest.split())
                current_field = "files"
            elif line.startswith("Copyright:"):
                cop_val = line[10:].strip()
                if cop_val:
                    cops.append(cop_val)
                current_field = "copyright"
            elif line.startswith("License:"):
                lic = line[8:].strip().split()[0] if line[8:].strip() else None
                current_field = "license"
            elif current_field == "files" and line.startswith(" ") and not line.startswith(" ."):
                files.extend(line.strip().split())
            elif current_field == "copyright" and line.startswith(" ") and line.strip():
                # Continuation line for Copyright (additional holders)
                cops.append(line.strip())
        if files and lic:
            for f in files:
                stanzas.append((f, lic))
                stanza_copyrights[f] = cops

# Also parse standalone License text blocks
license_blocks = {}  # {license_name: text_body}
if copyright_file and os.path.isfile(copyright_file):
    for para in copyright_text.split("\n\n"):
        lines = para.split("\n")
        if not lines:
            continue
        first = lines[0]
        has_files = any(l.startswith("Files:") for l in lines)
        if first.startswith("License:") and not has_files:
            lic_name = first[8:].strip().split()[0] if first[8:].strip() else None
            if lic_name:
                body_lines = []
                for l in lines[1:]:
                    # DEP-5: continuation lines start with space or " ."
                    if l.startswith(" ") or l == " .":
                        body_lines.append(l[1:] if l.startswith(" ") else "")
                    elif l.strip() == ".":
                        body_lines.append("")
                license_blocks[lic_name] = "\n".join(body_lines)

# ══════════════════════════════════════════════════════════════════════
# License text completeness checking
# ══════════════════════════════════════════════════════════════════════

# Licenses available in /usr/share/common-licenses/ on this system.
# Under snap strict confinement the host path is inaccessible, so fall back to
# the copy bundled inside the snap via the base-files stage-package.
SYSTEM_COMMON_LICENSES = set()
for _cl_dir in (
    "/usr/share/common-licenses",
    os.path.join(os.environ.get("SNAP", ""), "usr/share/common-licenses"),
):
    try:
        entries = os.listdir(_cl_dir)
        if entries:
            for entry in entries:
                SYSTEM_COMMON_LICENSES.add(entry)
            break
    except OSError:
        pass

def check_license_completeness():
    """Check each referenced license has a complete text block.

    Returns list of (license_name, severity, message) tuples.
    severity: 'error', 'warning', 'info'
    """
    issues = []
    # Collect all licenses referenced by file stanzas
    referenced = set(lic for _, lic in stanzas)
    if not referenced:
        return issues

    for lic in sorted(referenced):
        slug = lic.rstrip("+")

        # Check if it has a standalone License block
        if lic not in license_blocks:
            issues.append((lic, "error",
                f"No standalone License block found for '{lic}'"))
            continue

        body = license_blocks[lic]
        body_stripped = body.strip()
        body_lines = [l for l in body_stripped.split("\n") if l.strip()]
        text_len = len(body_stripped)

        # Check for FIXME/TODO placeholders
        if re.search(r'FIXME|TODO|PLACEHOLDER', body_stripped, re.IGNORECASE):
            issues.append((lic, "error",
                f"License '{lic}' contains FIXME/TODO placeholder"))
            continue

        # Check if it references /usr/share/common-licenses/
        cl_ref = re.search(r'/usr/share/common-licenses/([\w.+-]+)', body_stripped)
        if cl_ref:
            ref_name = cl_ref.group(1)
            if ref_name not in SYSTEM_COMMON_LICENSES and slug not in SYSTEM_COMMON_LICENSES:
                issues.append((lic, "error",
                    f"License '{lic}' references /usr/share/common-licenses/{ref_name} "
                    f"but that file does not exist on this system"))
            else:
                # Valid common-licenses reference, that's sufficient
                continue

        # ── Creative Commons specific checks ──
        # lintian specifically checks for incomplete CC licenses
        if re.match(r'^CC-BY', lic, re.IGNORECASE):
            # CC licenses are verbose — full text is typically 10KB+
            # A summary/abstract is usually < 2KB
            if text_len < 3000:
                issues.append((lic, "warning",
                    f"License '{lic}' appears to be a summary, not the full legal text "
                    f"({text_len} chars, full text is typically 10000+). "
                    f"lintian will flag this as 'incomplete-creative-commons-license'"))
                continue
            # Check for key full-text markers
            if not re.search(r'Section\s+[1-8]|BY EXERCISING|Creative Commons Corporation',
                             body_stripped):
                issues.append((lic, "warning",
                    f"License '{lic}' may not be the full legal text "
                    f"(missing expected legal code markers)"))
                continue

        # ── General completeness check ──
        # A real license text should have substantial content
        # Most open source licenses are at least 500 chars
        if text_len < 50:
            issues.append((lic, "error",
                f"License '{lic}' text block is nearly empty ({text_len} chars)"))
        elif text_len < 200 and slug not in SYSTEM_COMMON_LICENSES:
            issues.append((lic, "warning",
                f"License '{lic}' text block is very short ({text_len} chars) "
                f"and not in /usr/share/common-licenses/"))

    return issues

def check_coverage():
    """Check stanza coverage vs actual source files.

    Returns:
        uncovered: list of (filepath, detected_licenses) not matched by any stanza
        stale: list of (glob_pattern, license) that match no scanned file
    """
    # All scanned file paths (stripped of ./)
    scanned_paths = set(r["path"].lstrip("./") for r in scan_results)

    # 1) Files not covered by any stanza glob
    uncovered = []
    for r in scan_results:
        fp = r["path"].lstrip("./")
        matched = False
        for glob_pat, _ in stanzas:
            if fnmatch.fnmatch(fp, glob_pat) or glob_pat == "*":
                matched = True
                break
        if not matched:
            lics = [to_dep5(l) for l in r["licenses"]] if r["licenses"] else []
            uncovered.append((fp, lics))

    # 2) Stanza globs that match no scanned file (stale entries)
    stale = []
    seen_globs = set()
    for glob_pat, lic in stanzas:
        if glob_pat == "*":  # catch-all always "matches"
            continue
        if glob_pat in seen_globs:
            continue
        seen_globs.add(glob_pat)
        has_match = any(fnmatch.fnmatch(sp, glob_pat) for sp in scanned_paths)
        if not has_match:
            stale.append((glob_pat, lic))

    return uncovered, stale

def check_license_compatibility(declared_licenses):
    """Check for known license incompatibilities among declared licenses.

    Returns list of human-readable issue strings.
    """
    issues = []
    norms = {lic: norm_cmp(lic) for lic in declared_licenses}

    has_gpl2_only = any(n == "gpl-2" and not lic.endswith("+") for lic, n in norms.items())
    has_gpl2plus = any(n == "gpl-2+" or (n == "gpl-2" and lic.endswith("+")) for lic, n in norms.items())
    has_gpl3_only = any(n == "gpl-3" and not lic.endswith("+") for lic, n in norms.items())
    has_apache = any("apache" in n for n in norms.values())
    has_lgpl3 = any(n in ("lgpl-3", "lgpl-3+") for n in norms.values())
    has_cddl = any("cddl" in n for n in norms.values())
    has_mpl1 = any(n == "mpl-1.1" for n in norms.values())

    # Apache-2.0 vs GPL-2-only
    if has_apache and has_gpl2_only and not has_gpl2plus:
        issues.append(
            "Apache-2.0 is INCOMPATIBLE with GPL-2 (without 'or later'). "
            "This is a real license conflict that must be resolved.")
    elif has_apache and has_gpl2plus:
        issues.append(
            "NOTE: Apache-2.0 + GPL-2+ => effective GPL-3+. "
            "This is compatible for Debian.")

    # GPL-2-only + GPL-3-only (cannot satisfy both simultaneously)
    if has_gpl2_only and has_gpl3_only:
        issues.append(
            "GPL-2 (only) and GPL-3 (only) code cannot be combined — "
            "no single GPL version satisfies both.")

    # GPL-2-only + LGPL-3+ (LGPL-3 converts to GPL-3, incompatible with GPL-2-only)
    if has_gpl2_only and has_lgpl3 and not has_gpl2plus:
        issues.append(
            "LGPL-3 converts to GPL-3 for combined works, "
            "which is incompatible with GPL-2 (only).")

    # CDDL + GPL (any version, they are fundamentally incompatible)
    gpl_any = any("gpl" in n and "lgpl" not in n for n in norms.values())
    if has_cddl and gpl_any:
        issues.append(
            "CDDL and GPL are incompatible copyleft licenses. "
            "They cannot be combined in a single work.")

    # MPL-1.1 + GPL (MPL-1.1 is not GPL-compatible; MPL-2.0 is)
    if has_mpl1 and gpl_any:
        issues.append(
            "MPL-1.1 is not compatible with the GPL. "
            "Consider upgrading to MPL-2.0 which has a GPL compatibility clause.")

    # EPL-1.0 + GPL (Eclipse Public License 1.0 is GPL-incompatible)
    has_epl1 = any(n == "epl-1" for n in norms.values())
    has_epl2 = any(n == "epl-2" for n in norms.values())
    if has_epl1 and gpl_any:
        issues.append(
            "EPL-1.0 is INCOMPATIBLE with the GPL. "
            "EPL-2.0 with secondary license notice may allow GPL combination.")
    # EPL-2.0 note (compatible only with secondary license exception)
    if has_epl2 and gpl_any:
        issues.append(
            "NOTE: EPL-2.0 is GPL-compatible ONLY if the code specifies a "
            "'Secondary License' (GPL-2.0). Check EPL-2.0 headers for this clause.")

    # OSL-3.0 + GPL (Open Software License — copyleft, GPL-incompatible)
    has_osl = any("osl" in n for n in norms.values())
    if has_osl and gpl_any:
        issues.append(
            "OSL (Open Software License) is INCOMPATIBLE with the GPL. "
            "Both are copyleft but mutually exclusive.")

    # OpenSSL + GPL (advertising clause makes it GPL-incompatible)
    has_openssl = any("openssl" in n for n in norms.values())
    if has_openssl and gpl_any:
        issues.append(
            "OpenSSL license is INCOMPATIBLE with the GPL due to its "
            "advertising clause. Use a GPL exception or replace OpenSSL.")

    # BSD-4-Clause + GPL (advertising clause makes it GPL-incompatible)
    has_bsd4 = any(n == "bsd-4-clause" for n in norms.values())
    if has_bsd4 and gpl_any:
        issues.append(
            "BSD-4-Clause (original BSD) is INCOMPATIBLE with the GPL "
            "due to its advertising clause. Use BSD-3-Clause instead.")

    # QPL-1.0 + GPL (Qt Public License — cannot link with GPL code)
    has_qpl = any(n == "qpl-1" for n in norms.values())
    if has_qpl and gpl_any:
        issues.append(
            "QPL-1.0 is INCOMPATIBLE with the GPL for linked/combined works. "
            "QPL-licensed code cannot be combined with GPL code in a single program.")

    return issues

def check_dep5_format():
    """Validate DEP-5 structural/format compliance of debian/copyright.

    Returns list of (line_number, severity, message, fix_tag) tuples.
    fix_tag is a string identifying the auto-fix category, or None.
    """
    issues = []
    if not copyright_file or not os.path.isfile(copyright_file):
        return issues

    with open(copyright_file, encoding="utf-8") as f:
        raw = f.read()
    lines = raw.split("\n")

    # ── 1. Header paragraph: must start with Format: ─────────────
    paragraphs = raw.split("\n\n")
    if paragraphs:
        header = paragraphs[0]
        header_lines = header.split("\n")
        if not header_lines or not header_lines[0].startswith("Format:"):
            issues.append((1, "error",
                "First line must be a Format: field "
                "(e.g. Format: https://www.debian.org/doc/packaging-manuals/"
                "copyright-format/1.0/)", "missing-format"))
        else:
            fmt_url = header_lines[0][7:].strip()
            if "debian.org" not in fmt_url:
                issues.append((1, "warning",
                    f"Format URL looks non-standard: {fmt_url}", None))

        # ── 2. Recommended header fields ─────────────────────────
        hdr_fields = set()
        for hl in header_lines:
            m = re.match(r'^([A-Z][\w-]+):', hl)
            if m:
                hdr_fields.add(m.group(1))
        for rec in ("Upstream-Name", "Upstream-Contact", "Source"):
            if rec not in hdr_fields:
                issues.append((1, "warning",
                    f"Header paragraph missing recommended field: {rec}",
                    None))

    # ── 3. Multiple consecutive blank lines ──────────────────────
    for i, line in enumerate(lines):
        if i > 0 and line == "" and lines[i - 1] == "":
            issues.append((i + 1, "warning",
                "Multiple consecutive blank lines "
                "(paragraphs should be separated by exactly one blank line)",
                "multi-blank"))

    # ── 4. Trailing whitespace ───────────────────────────────────
    for i, line in enumerate(lines):
        if line != line.rstrip():
            issues.append((i + 1, "warning",
                f"Trailing whitespace on line {i + 1}", "trailing-ws"))

    # ── 5. Tab indentation in continuation lines ─────────────────
    for i, line in enumerate(lines):
        if line.startswith("\t"):
            issues.append((i + 1, "error",
                f"Tab indentation on line {i + 1} "
                "(DEP-5 continuation lines must use spaces, not tabs)",
                "tab-indent"))

    # ── 6. Blank continuation lines must be " ." ─────────────────
    in_block = False
    for i, line in enumerate(lines):
        if re.match(r'^[A-Z][\w-]+:', line):
            in_block = True
        elif line == "":
            in_block = False
        elif in_block and line.rstrip() == "" and line != "":
            # Line is all whitespace but not empty — should be " ."
            issues.append((i + 1, "error",
                f"Blank continuation line {i + 1} must be ' .' "
                "(space followed by period), not just whitespace",
                "blank-continuation"))

    # ── 7. File stanzas: required fields ─────────────────────────
    para_line = 1
    for para in paragraphs:
        plines = para.split("\n")
        fields = []
        for pl in plines:
            m = re.match(r'^([A-Z][\w-]+):', pl)
            if m:
                fields.append(m.group(1))

        has_files = "Files" in fields
        has_copyright = "Copyright" in fields
        has_license = "License" in fields

        if has_files:
            if not has_copyright:
                issues.append((para_line, "error",
                    f"Files stanza at line {para_line} missing required "
                    "Copyright: field", None))
            if not has_license:
                issues.append((para_line, "error",
                    f"Files stanza at line {para_line} missing required "
                    "License: field", None))
            # Check field ordering: Files before Copyright before License
            fi = fields.index("Files") if "Files" in fields else -1
            ci = fields.index("Copyright") if "Copyright" in fields else -1
            li = fields.index("License") if "License" in fields else -1
            if ci >= 0 and fi >= 0 and ci < fi:
                issues.append((para_line, "warning",
                    f"Files stanza at line {para_line}: Copyright: should "
                    "come after Files:", "field-order"))
            if li >= 0 and ci >= 0 and li < ci:
                issues.append((para_line, "warning",
                    f"Files stanza at line {para_line}: License: should "
                    "come after Copyright:", "field-order"))

        # Standalone License block must have body
        if has_license and not has_files and not plines[0].startswith("Format:"):
            body_lines = [l for l in plines[1:] if l.startswith(" ") or l == " ."]
            if not body_lines:
                lic_name = plines[0][8:].strip().split()[0] if plines[0][8:].strip() else "?"
                issues.append((para_line, "error",
                    f"Standalone License block '{lic_name}' at line "
                    f"{para_line} has no body text", None))

        # ── 8. Unrecognized fields ───────────────────────────────
        KNOWN_FIELDS = {
            "Format", "Upstream-Name", "Upstream-Contact", "Source",
            "Disclaimer", "Comment", "License", "Copyright", "Files",
            "Files-Excluded", "Files-Excluded-DFSG",
        }
        for pl in plines:
            m = re.match(r'^([A-Z][\w-]+):', pl)
            if m and m.group(1) not in KNOWN_FIELDS:
                lnum = para_line + plines.index(pl)
                issues.append((lnum, "warning",
                    f"Unrecognized field '{m.group(1)}' at line {lnum}",
                    None))

        para_line += len(plines) + 1  # +1 for blank separator

    # ── 9. Catch-all stanza ──────────────────────────────────────
    has_catchall = any(g == "*" for g, _ in stanzas)
    if not has_catchall and stanzas:
        issues.append((0, "warning",
            "No catch-all 'Files: *' stanza found (recommended)", None))

    # ── 10. Duplicate file globs ─────────────────────────────────
    glob_counts = defaultdict(int)
    for g, _ in stanzas:
        glob_counts[g] += 1
    for g, count in glob_counts.items():
        if count > 1:
            issues.append((0, "warning",
                f"File glob '{g}' appears in {count} stanzas "
                "(later stanzas override earlier ones)", None))

    # ── 11. File does not end with newline ────────────────────────
    if raw and not raw.endswith("\n"):
        issues.append((len(lines), "warning",
            "File does not end with a newline", "missing-newline"))

    return issues

def fix_dep5_format(text):
    """Apply automatic DEP-5 format fixes to the copyright text.

    Returns (fixed_text, list_of_fix_descriptions).
    """
    fixes = []

    # Fix trailing whitespace
    new_lines = []
    trailing_fixed = 0
    for line in text.split("\n"):
        stripped = line.rstrip()
        if stripped != line:
            trailing_fixed += 1
        new_lines.append(stripped)
    if trailing_fixed > 0:
        fixes.append(f"Removed trailing whitespace from {trailing_fixed} line(s)")
    text = "\n".join(new_lines)

    # Fix multiple consecutive blank lines
    old_len = len(text)
    while "\n\n\n" in text:
        text = text.replace("\n\n\n", "\n\n")
    if len(text) != old_len:
        fixes.append("Collapsed multiple consecutive blank lines")

    # Fix tab indentation → spaces
    tab_count = 0
    new_lines = []
    for line in text.split("\n"):
        if line.startswith("\t"):
            line = " " + line.lstrip("\t")
            tab_count += 1
        new_lines.append(line)
    if tab_count > 0:
        fixes.append(f"Replaced tab indentation with spaces on {tab_count} line(s)")
    text = "\n".join(new_lines)

    # Fix blank continuation lines (whitespace-only → " .")
    in_block = False
    new_lines = []
    blank_cont_fixed = 0
    for line in text.split("\n"):
        if re.match(r'^[A-Z][\w-]+:', line):
            in_block = True
            new_lines.append(line)
        elif line == "":
            in_block = False
            new_lines.append(line)
        elif in_block and line.rstrip() == "" and line != "":
            new_lines.append(" .")
            blank_cont_fixed += 1
        else:
            new_lines.append(line)
    if blank_cont_fixed > 0:
        fixes.append(f"Fixed {blank_cont_fixed} blank continuation line(s) → ' .'")
    text = "\n".join(new_lines)

    # Ensure file ends with newline
    if text and not text.endswith("\n"):
        text += "\n"
        fixes.append("Added missing trailing newline")

    return text, fixes

def get_declared_license(filepath):
    """Return the license declared for filepath using DEP-5 last-match-wins rule."""
    fp = filepath.lstrip("./")
    best = None
    # DEP-5 spec: when multiple stanzas match, the last one wins
    for glob, lic in stanzas:
        if fnmatch.fnmatch(fp, glob) or glob == "*":
            best = lic
    return best

def get_declared_copyrights(filepath):
    """Return the copyright holders declared for filepath (last-match-wins)."""
    fp = filepath.lstrip("./")
    best = []
    for glob, lic in stanzas:
        if fnmatch.fnmatch(fp, glob) or glob == "*":
            best = stanza_copyrights.get(glob, [])
    return best

# Corporate suffixes that should never start a new author entry
# when preceded by a comma (e.g. "Company, Inc.").
_CORP_SUFFIXES_RE = re.compile(
    r'^(?:Inc|Ltd|LLC|LLP|GmbH|AG|Co|Corp|Pty|SA|SAS|BV|NV'
    r'|Srl|SpA|KG|OHG|AB|AS|Oy|Bhd|Pte|SE|PLC|plc)\.?(?:\s|$)',
    re.IGNORECASE)

def _deobfuscate_email(s):
    """Convert obfuscated emails to real ones and normalise brackets.

    'alice at example dot com'       → 'alice@example.com'
    '(user@example.com)'             → '<user@example.com>'
    '(user at example dot com)'      → '<user@example.com>'
    '(bob dot smith@example.org)'    → '<bob.smith@example.org>'
    """
    # Deobfuscate "word at word dot word" patterns
    def _deob(m):
        return m.group(0).replace(' at ', '@').replace(' dot ', '.')
    s = re.sub(r'\b\w[\w.+-]* at \w[\w.-]* dot \w+', _deob, s)
    # Deobfuscate partial: "word dot word@domain" (has @ but still has ' dot ')
    def _deob_partial(m):
        return m.group(0).replace(' dot ', '.')
    s = re.sub(r'\b\w[\w.+-]* dot \w[\w.+-]*@[\w.-]+', _deob_partial, s)
    # Convert parenthesized email to angle brackets
    s = re.sub(r'\(([\w.+-]+@[\w.-]+)\)', r'<\1>', s)
    return s

def _strip_email(s):
    """Remove <email> from a string."""
    return re.sub(r'\s*<[^>]*>', '', s).strip()

def _extract_email(s):
    """Extract the first email address from a string, or None."""
    m = re.search(r'<([^>]+)>', s)
    return m.group(1).lower() if m else None

def _normalize_unicode(s):
    """Decompose unicode and strip combining marks (accents).
    Also maps ß→ss (not decomposed by NFKD)."""
    nfkd = unicodedata.normalize('NFKD', s)
    result = ''.join(c for c in nfkd if unicodedata.category(c) != 'Mn')
    return result.replace('ß', 'ss').replace('ẞ', 'SS')

def norm_copyright(s):
    """Normalize a copyright string for fuzzy comparison.
    Strips year ranges, (c)/(C) markers, 'Copyright' prefix, email addresses,
    unicode accents, extra whitespace.
    Returns None if nothing meaningful remains."""
    s = s.strip()
    s = re.sub(r'(?i)copyright\s*', '', s)
    s = re.sub(r'\(c\)', '', s, flags=re.IGNORECASE)
    s = re.sub(r'©', '', s)
    # Remove year ranges: 2020, 2020-2024, 2020 - 2024, etc.
    s = re.sub(r'\d{4}\s*[-–]\s*\d{4}', '', s)
    s = re.sub(r'\d{4}', '', s)
    # Strip email addresses for comparison
    s = re.sub(r'\s*<[^>]*>', '', s)
    s = re.sub(r'[,;]\s*', ' ', s)
    s = re.sub(r'\s+', ' ', s).strip()
    # Normalize unicode (strip accents)
    s = _normalize_unicode(s)
    result = s.lower()
    return result if result else None

_YEAR_RE = re.compile(r'\b(\d{4})\b')
_YEAR_RANGE_RE = re.compile(r'\b(\d{4})\s*[-–]\s*(\d{4})\b')
_COPYRIGHT_PREFIX_RE = re.compile(
    r'^(?:copyright\s*)?(?:\(c\)|©)?\s*(?:copyright\s*)?\s*', re.IGNORECASE)

def _parse_copyright(s):
    """Split a raw copyright string into (set_of_years, author_name).
    Returns (years: set[int], author: str)."""
    years = set()
    for lo, hi in _YEAR_RANGE_RE.findall(s):
        for y in range(int(lo), int(hi) + 1):
            years.add(y)
    for y in _YEAR_RE.findall(s):
        years.add(int(y))
    # Strip prefix, years, ranges, commas between years, leading "by"
    author = _COPYRIGHT_PREFIX_RE.sub('', s)
    author = _YEAR_RANGE_RE.sub('', author)
    author = _YEAR_RE.sub('', author)
    author = re.sub(r'^[\s,;-]+|[\s,;-]+$', '', author)
    author = re.sub(r'^by\s+', '', author, flags=re.IGNORECASE)
    author = re.sub(r'\s+', ' ', author).strip()
    return years, author

def _split_multi_authors(author_str):
    """Split a string containing multiple comma/and-separated authors.

    Handles patterns like:
      "Alice Brown, Bob Smith, and Carol Jones"
      "John Doe and Jane Doe"
    But does NOT split location qualifiers like:
      "Example GmbH, Munich."  → kept as one holder
      "Acme Ltd, Auckland, New Zealand" → kept as one holder
    Returns a list of individual author strings.
    """
    if not author_str:
        return [author_str]

    # When the string contains explicit "and"/"&", it is very likely
    # a multi-author list, so use a stricter location threshold (1 word)
    # to avoid merging real person names like "Bob Smith".
    has_explicit_sep = bool(re.search(r'\band\b|&', author_str,
                                      flags=re.IGNORECASE))
    loc_max_words = 1 if has_explicit_sep else 2

    # First split on explicit "and" / "&" separators — these always
    # indicate distinct authors.
    and_parts = re.split(
        r',\s*and\s+|,\s*&\s+|\s+and\s+|\s+&\s+',
        author_str, flags=re.IGNORECASE)
    and_parts = [p.strip() for p in and_parts if p and p.strip()]

    # Within each and-part, split on commas — but rejoin fragments
    # that look like locations (no year, no email, few words).
    result = []
    for and_part in and_parts:
        comma_parts = re.split(r',\s+', and_part)
        comma_parts = [p.strip() for p in comma_parts
                       if p and len(p.strip()) > 1]
        if not comma_parts:
            if and_part.strip():
                result.append(and_part.strip())
            continue
        merged = [comma_parts[0]]
        for p in comma_parts[1:]:
            # Corporate suffixes (Inc., Ltd., etc.) always rejoin
            if _CORP_SUFFIXES_RE.match(p.strip()):
                merged[-1] += ", " + p
                continue
            clean = re.sub(r'(?i)\.\s*all\s+rights\s+reserved\.?', '', p)
            clean = re.sub(r'[.\s]+$', '', clean).strip()
            has_email = '<' in p or '@' in p
            has_year = bool(re.search(r'\b\d{4}\b', p))
            word_count = len(clean.split())
            if not has_email and not has_year and word_count <= loc_max_words:
                # Likely a location qualifier — rejoin with previous
                merged[-1] += ", " + p
            else:
                merged.append(p)
        result.extend(merged)
    return result if result else [author_str]

def _infer_years_from_paths(paths):
    """Infer copyright years from file modification times.

    Tries git log for earliest commit year first, falls back to mtime.
    Returns a set of ints.
    """
    years = set()
    # Try git to get first-commit year per file (fast batch call)
    git_ok = os.path.isdir(".git")
    if git_ok and paths:
        try:
            clean = [p.lstrip("./") for p in paths if p]
            # Process in batches to avoid OS argument length limits
            _BATCH = 200
            for _bi in range(0, len(clean), _BATCH):
                _chunk = clean[_bi:_bi + _BATCH]
                result = subprocess.run(
                    ["git", "log", "--follow", "--diff-filter=A",
                     "--format=%ai", "--"] + _chunk,
                    capture_output=True, text=True, timeout=10)
                for line in result.stdout.splitlines():
                    line = line.strip()
                    if line and len(line) >= 4:
                        try:
                            years.add(int(line[:4]))
                        except ValueError:
                            pass
        except (OSError, subprocess.TimeoutExpired):
            pass
    # Fall back to mtime for files we couldn't get git info for
    if not years:
        for p in paths:
            clean_p = p.lstrip("./")
            try:
                mtime = os.path.getmtime(clean_p)
                years.add(datetime.datetime.fromtimestamp(mtime).year)
            except (OSError, ValueError):
                pass
    return years

def merge_copyrights(raw_list, prefer_unicode=None, file_paths=None):
    """Merge a list of raw copyright strings, combining years per author.

    Returns a list of formatted copyright lines, one per unique author,
    with years collapsed into ranges.
    Example: '2014-2016, 2020 David Edmundson <dave@kde.org>'

    If prefer_unicode is a dict mapping norm_key -> author string,
    any matching author will be replaced with the preferred (non-ASCII)
    variant.
    """
    # Group years by normalized author key → keep best-case original author
    author_years = {}    # norm_key → set of years
    author_best = {}     # norm_key → original author string (longest wins)
    email_to_key = {}    # email → first norm_key seen (for email-based dedup)

    def _author_score(a):
        has_nonascii = any(ord(c) > 127 for c in a)
        return (has_nonascii, len(a))

    # Placeholder values that scanners emit for unrecognized holders
    _PLACEHOLDER_HOLDERS = frozenset({
        "unknown", "fixme", "todo", "none", "n/a", "no copyright",
    })

    for raw in raw_list:
        if not raw or not raw.strip():
            continue
        raw = _deobfuscate_email(raw)
        years, author = _parse_copyright(raw)
        if not author:
            continue
        if author.lower().strip() in _PLACEHOLDER_HOLDERS:
            continue
        # Split multi-author strings ("A, B and C" → ["A", "B", "C"])
        individual_authors = _split_multi_authors(author)
        for indiv in individual_authors:
            if not indiv or indiv.lower().strip() in _PLACEHOLDER_HOLDERS:
                continue
            # Primary key: name without email, unicode-normalized, lowered
            name_only = _strip_email(indiv)
            key = _normalize_unicode(name_only).lower()
            # Email-based dedup: if two entries share the same email, merge them
            email = _extract_email(indiv)
            if email and email in email_to_key:
                key = email_to_key[email]
            elif email:
                email_to_key[email] = key
            if key not in author_years:
                author_years[key] = set()
                author_best[key] = indiv
            author_years[key].update(years)
            # Keep the best variant: prefer non-ASCII (proper unicode names)
            # over ASCII-only, then longest among same category.
            if _author_score(indiv) > _author_score(author_best[key]):
                author_best[key] = indiv

    # Secondary dedup: merge entries whose names match when whitespace
    # and hyphens are stripped.  Catches CamelCase/concatenated usernames
    # (e.g. "PushkarDeshpande") matching spaced names ("Pushkar Deshpande").
    compressed_map = {}  # compressed_key → canonical_key
    for key in sorted(author_years,
                      key=lambda k: (-len(author_best.get(k, '')), k)):
        ck = re.sub(r'[\s\-]+', '', key)
        if ck in compressed_map:
            canon = compressed_map[ck]
            author_years[canon].update(author_years.pop(key))
            if _author_score(author_best[key]) > _author_score(author_best[canon]):
                author_best[canon] = author_best[key]
            del author_best[key]
        else:
            compressed_map[ck] = key

    # Tertiary dedup: fuzzy match by edit distance to catch typos
    # like "Kontros" vs "Krontros" or "Adolfo" vs "Adolpho".
    def _edit_dist(a, b):
        if len(a) < len(b):
            a, b = b, a
        prev = list(range(len(b) + 1))
        for i, ca in enumerate(a):
            curr = [i + 1]
            for j, cb in enumerate(b):
                curr.append(min(prev[j + 1] + 1, curr[j] + 1,
                                prev[j] + (ca != cb)))
            prev = curr
        return prev[-1]

    remaining = list(author_years.keys())
    merged = set()
    for i, k1 in enumerate(remaining):
        if k1 in merged:
            continue
        ck1 = re.sub(r'[\s\-]+', '', k1)
        for k2 in remaining[i + 1:]:
            if k2 in merged:
                continue
            ck2 = re.sub(r'[\s\-]+', '', k2)
            if len(ck1) < 8 or len(ck2) < 8:
                continue
            if _edit_dist(ck1, ck2) <= 2:
                author_years[k1].update(author_years.pop(k2))
                if _author_score(author_best[k2]) > _author_score(author_best[k1]):
                    author_best[k1] = author_best[k2]
                del author_best[k2]
                merged.add(k2)

    def _fmt_years(yrs):
        """Collapse a set of years into compact ranges: 2014-2016, 2020."""
        if not yrs:
            return ""
        parts = []
        syrs = sorted(yrs)
        start = prev = syrs[0]
        for y in syrs[1:]:
            if y == prev + 1:
                prev = y
            else:
                parts.append(f"{start}-{prev}" if prev > start else str(start))
                start = prev = y
        parts.append(f"{start}-{prev}" if prev > start else str(start))
        return ", ".join(parts)

    # Apply unicode preferences from existing declarations
    if prefer_unicode:
        for key in author_best:
            if key in prefer_unicode:
                pref = prefer_unicode[key]
                cur = author_best[key]
                if any(ord(c) > 127 for c in pref) and not any(ord(c) > 127 for c in cur):
                    author_best[key] = pref

    # Infer fallback years for authors with no detected years
    has_yearless = any(not author_years[k] for k in author_years)
    if has_yearless:
        # First try: use years from peer authors in the same merge.
        # All raw copyrights cover the same files, so peer years are
        # the best available signal.
        peer_yrs = set()
        for k in author_years:
            peer_yrs.update(author_years[k])
        if peer_yrs:
            for key in author_years:
                if not author_years[key]:
                    author_years[key] = set(peer_yrs)
        # Second try: infer from file modification / git history.
        elif file_paths:
            fallback_yrs = _infer_years_from_paths(file_paths)
            if fallback_yrs:
                for key in author_years:
                    if not author_years[key]:
                        author_years[key] = set(fallback_yrs)

    lines = []
    for key in sorted(author_years, key=lambda k: (
            min(author_years[k]) if author_years[k] else 9999, k)):
        yrs = _fmt_years(author_years[key])
        name = author_best[key]
        if yrs:
            lines.append(f"{yrs} {name}")
        else:
            lines.append(name)
    return lines

def format_files_field(globs, max_col=80):
    """Format a complete Files: field with continuation indentation."""
    prefix = "Files: "
    indent = " " * len(prefix)
    lines = []
    for i, g in enumerate(globs):
        if i == 0:
            lines.append(prefix + g)
        else:
            lines.append(indent + g)
    return "\n".join(lines)

def _copyright_continuations(holders, max_col=80, indent=None):
    """Format holders as indented copyright continuation lines."""
    if indent is None:
        indent = " " * 11
    avail = max_col - len(indent)
    parts = []
    for h in holders:
        if len(h) <= avail:
            parts.append(indent + h)
        else:
            wrapped = textwrap.wrap(
                h, width=avail,
                break_long_words=False, break_on_hyphens=False)
            for wl in (wrapped or [h]):
                parts.append(indent + wl)
    return "\n".join(parts)

def format_copyright_field(merged_lines, max_col=80):
    """Format merged copyright lines into a DEP-5 Copyright: field value.
    First line follows 'Copyright:', subsequent lines are continuation.
    Wraps individual entries that would exceed max_col."""
    if not merged_lines:
        return "FIXME"
    indent = " " * 11
    avail = max_col - 11
    parts = []
    for i, line in enumerate(merged_lines):
        if len(line) <= avail:
            if i == 0:
                parts.append(line)
            else:
                parts.append(indent + line)
        else:
            wrapped = textwrap.wrap(
                line, width=avail,
                break_long_words=False, break_on_hyphens=False)
            for j, wl in enumerate(wrapped or [line]):
                if i == 0 and j == 0:
                    parts.append(wl)
                else:
                    parts.append(indent + wl)
    return "\n".join(parts)

def check_copyright_holders():
    """Compare detected copyright holders against declared ones per stanza.
    Returns: (missing, extra, star_file_map, holder_file_map)
      missing: [(glob, detected_holder)] — detected but not declared
      extra: [(glob, declared_holder)] — declared but not found in any scanned file
      star_file_map: {holder_string: set_of_file_paths} — for the * glob only,
        maps each missing holder to the files where it was detected
      holder_file_map: {(glob, holder_string): set_of_file_paths} — for ALL globs,
        maps each (glob, holder) to the specific files where it was detected
    """
    # In DEP-5, when multiple stanzas match a file, the last one wins.
    # Map each file's copyrights only to its governing stanza.
    detected_per_glob = defaultdict(set)
    declared_per_glob = {}
    # For the * glob, also track which files contribute each holder
    star_holder_files = defaultdict(set)  # holder_string → set of filepaths
    # Track per-file attribution for ALL globs
    holder_file_map = defaultdict(set)  # (glob, holder) → set of filepaths

    for glob_pat, lic in stanzas:
        declared_per_glob[glob_pat] = set(stanza_copyrights.get(glob_pat, []))

    # For each scanned file, find its governing stanza (last match wins)
    for r in scan_results:
        fp = r["path"].lstrip("./")
        # Skip license/copying text files — copyright notices in license texts
        # (e.g. FSF's copyright on the GPL text) are not project copyrights.
        if Path(fp).name.lower() in _LICENSE_FILE_NAMES:
            continue
        governing_glob = None
        for glob_pat, lic in stanzas:
            if fnmatch.fnmatch(fp, glob_pat) or glob_pat == "*":
                governing_glob = glob_pat
        if governing_glob is not None:
            for c in r.get("copyrights", []):
                if c:
                    detected_per_glob[governing_glob].add(c)
                    holder_file_map[(governing_glob, c)].add(fp)
                    if governing_glob == "*":
                        star_holder_files[c].add(fp)

    missing_holders = []  # (glob, detected_holder_not_declared)
    extra_holders = []    # (glob, declared_holder_not_detected)

    # Placeholder values that scanners emit for unrecognized holders
    _placeholder_holders = frozenset({
        "unknown", "fixme", "todo", "none", "n/a", "no copyright",
    })

    for glob_pat in declared_per_glob:
        declared_set = declared_per_glob[glob_pat]
        detected_set = detected_per_glob.get(glob_pat, set())

        declared_norms = {norm_copyright(d): d for d in declared_set
                          if norm_copyright(d)}
        detected_norms = {norm_copyright(d): d for d in detected_set
                          if norm_copyright(d) and
                          _parse_copyright(d)[1].lower().strip()
                          not in _placeholder_holders}

        # Detected but not declared (new authors)
        for dn, original in detected_norms.items():
            if not dn:
                continue
            if not any(dn in dk or dk in dn for dk in declared_norms):
                missing_holders.append((glob_pat, original))

        # Declared but not detected (stale authors)
        for dk, original in declared_norms.items():
            if not dk:
                continue
            if not any(dk in dn or dn in dk for dn in detected_norms):
                extra_holders.append((glob_pat, original))

    return missing_holders, extra_holders, star_holder_files, holder_file_map

