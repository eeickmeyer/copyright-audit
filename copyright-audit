            lic_idx = None
            lic_name = None
            for idx, line in enumerate(lines):
                if line.startswith("License:"):
                    lic_val = line[8:].strip()
                    lic_name = lic_val.split()[0] if lic_val else None
                    lic_idx = idx
                    break
            if lic_idx is None or lic_name is None:
                new_paras.append(para)
                continue
            # Check if there are continuation lines after License:
            has_body = (lic_idx + 1 < len(lines)
                        and lines[lic_idx + 1].startswith(" "))
            if not has_body:
                new_paras.append(para)
                continue
            # Only strip if it's a common license
            if (lic_name not in _COMMON_LICENSES_FIX8
                    and lic_name not in SYSTEM_COMMON_LICENSES):
                new_paras.append(para)
                continue
            # Strip the inline body (continuation lines after License:)
            trimmed = lines[:lic_idx + 1]
            fix8_count += 1
            standalone_needed.add(lic_name)
            new_paras.append("\n".join(trimmed))

        if fix8_count:
            working_text = "\n\n".join(new_paras)
            changes_made += 1
            # Ensure standalone License: blocks exist for stripped licenses
            for lic in sorted(standalone_needed):
                # Check if a standalone block already exists
                has_block = False
                for block_para in working_text.split("\n\n"):
                    block_lines = block_para.strip().split("\n")
                    if not block_lines:
                        continue
                    first = block_lines[0]
                    has_f = any(l.strip().startswith("Files:")
                               for l in block_lines)
                    if (first.startswith("License:") and not has_f
                            and first[8:].strip().split()[0] == lic):
                        has_block = True
                        break
                if not has_block:
                    slug = lic.rstrip("+")
                    block = (f"\nLicense: {lic}\n"
                             f" On Debian systems, the full text of"
                             f" this license can be found in\n"
                             f" `/usr/share/common-licenses/{slug}'.\n")
                    working_text = working_text.rstrip("\n") + "\n" + block
            print(f"Replaced inline license text with common-licenses"
                  f" reference in {fix8_count} stanza(s).\n")

        # ── Write result ─────────────────────────────────────────────
        if changes_made > 0:
            # Clean up any double-blank-lines introduced
            while "\n\n\n" in working_text:
                working_text = working_text.replace("\n\n\n", "\n\n")
            working_text = working_text.rstrip("\n") + "\n"

            print(f"\n{changes_made} fix(es) ready to apply.")
            answer = ask(f"Write changes to {copyright_file}? [y/N] ").strip().lower()
            if answer in ("y", "yes"):
                # Write backup
                backup = copyright_file + ".bak"
                with open(backup, "w", encoding="utf-8") as f:
                    f.write(original_text)
                with open(copyright_file, "w", encoding="utf-8") as f:
                    f.write(working_text)
                print(f"\n  ✓ Written to {copyright_file}")
                print(f"  ✓ Backup saved to {backup}")
                _warn_stubs(working_text, copyright_file)
            else:
                # Offer to write to a different file
                alt = ask("  Write to alternate file instead? [path or Enter to discard] ").strip()
                if alt:
                    with open(alt, "w", encoding="utf-8") as f:
                        f.write(working_text)
                    print(f"  ✓ Written to {alt}")
                    _warn_stubs(working_text, alt)
                else:
                    print("  Changes discarded.")
        else:
            print("No fixes applied.")
        print()

    # ── Decopy-generated: output the hardened file to stdout ──────────
    if _decopy_generated:
        final_text = ""
        if os.path.isfile(copyright_file):
            with open(copyright_file, encoding="utf-8") as f:
                final_text = f.read()
        if _saved_stdout is not None:
            sys.stdout = _saved_stdout
        if not output_file:
            sys.stdout.write(final_text)
        else:
            print(f"Generated copyright written to: {copyright_file}",
                  file=sys.stderr)
