def run_sanity_check():
    """Cross-validate scancode results against licensecheck findings.
    Returns list of (path, scancode_lics, licensecheck_lics) tuples where
    the tools disagree on the detected license family."""
    if not sanity_results:
        return []

    # Build lookup from primary scan results
    primary = {}
    for r in scan_results:
        fp = r["path"]
        primary[fp] = set(r["licenses"])

    discrepancies = []
    for fp, lc_lics in sanity_results.items():
        # Normalize path
        norm = "./" + fp.lstrip("./")
        sc_lics = primary.get(norm, set())
        if not sc_lics and not lc_lics:
            continue
        # Normalize for comparison: strip versions, lowercase
        def _family(lic):
            s = re.sub(r'[- ]\d[\d.]*\+?$', '', lic).strip()
            return s.lower().replace("-", "").replace("_", "").replace(" ", "")
        sc_families = {_family(l) for l in sc_lics if l}
        lc_families = {_family(l) for l in lc_lics if l}
        # Skip if either found nothing (one tool may not detect headers)
        if not sc_families or not lc_families:
            continue
        # Flag if no overlap at all between the two tools
        if not sc_families & lc_families:
            discrepancies.append((
                norm,
                ", ".join(sorted(sc_lics)) or "(none)",
                ", ".join(sorted(lc_lics)) or "(none)",
            ))
    return discrepancies

