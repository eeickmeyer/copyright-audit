# MODE: generate — build a debian/copyright from scan results
# ══════════════════════════════════════════════════════════════════════
if mode == "generate":
    # Collect per-file data, skipping metadata/infrastructure files
    # (those are covered by the Files: * catch-all stanza).
    file_entries = []
    for idx, r in enumerate(scan_results, 1):
        progress(idx, total_files, "Grouping")
        if not r["licenses"]:
            continue
        fp = r["path"].lstrip("./")
        if is_metadata_file(fp):
            continue  # covered by Files: * catch-all
        lic_key = tuple(sorted(set(to_dep5(l) for l in r["licenses"])))
        file_entries.append({"path": fp, "lic": lic_key, "cops": list(r["copyrights"])})

    # Count files per license to pick the catch-all license
    lic_counts = defaultdict(int)
    for e in file_entries:
        lic_counts[e["lic"]] += 1
    if not lic_counts:
        print("No licenses detected in any file. Nothing to generate.", file=sys.stderr)
        sys.exit(1)
    biggest_key = max(lic_counts, key=lambda k: lic_counts[k])

    def _copyright_holder_key(cop):
        """Extract normalized author identity from a copyright string,
        stripping year ranges, emails, and spaces so that the same person
        with different formatting is recognized as one author."""
        s = cop.strip()
        s = re.sub(r'^(?:Copyright\s+)?(?:\(c\)\s+)?', '', s, flags=re.I)
        s = re.sub(r'^[\d,\s-]+', '', s).strip()
        s = re.sub(r'\s*<[^>]*>', '', s)   # strip email
        s = re.sub(r'[\s\-]+', '', s)      # collapse spaces/hyphens
        return s.lower()

    def _filter_debian(paths):
        if is_native:
            return paths
        return [p for p in paths if not p.startswith("debian/")]

    # ── Build per-author stanza groups ───────────────────────────────
    # Group files by (license, normalized-copyright-holder-set) so that
    # files with the same author(s) and license share a stanza.  This
    # produces per-author attribution rather than broad dir/* globs
    # that lump unrelated copyright holders together.
    root_catchall_cops = set()
    stanza_groups = defaultdict(lambda: {"paths": [], "cops": []})
    for e in file_entries:
        d = str(Path(e["path"]).parent)
        if e["lic"] == biggest_key and d == ".":
            root_catchall_cops.update(e["cops"])
            continue
        # Group by (license, normalized author set)
        author_key = frozenset(
            _copyright_holder_key(c) for c in e["cops"] if c.strip())
        sk = (e["lic"], author_key)
        stanza_groups[sk]["paths"].append(e["path"])
        stanza_groups[sk]["cops"].extend(e["cops"])

    # Count scanned non-metadata files per directory (for dir/* decision)
    dir_file_counts = defaultdict(int)
    for e in file_entries:
        d = str(Path(e["path"]).parent)
        if d != ".":
            dir_file_counts[d] += 1

    def smart_glob(paths):
        """Use dir/* only when every scanned non-metadata file in a
        directory belongs to this group; otherwise list individual files.
        Then merge sibling dir/* globs sharing a common prefix."""
        dirs = defaultdict(list)
        for p in paths:
            d = str(Path(p).parent)
            dirs[d].append(p)
        all_dirs = set(dirs.keys())
        result = []
        for d, files in sorted(dirs.items()):
            # Don't glob a dir if subdirs of it also appear in the
            # file list — dir/* in DEP-5 matches recursively.
            has_subdirs = any(od != d and od.startswith(d + "/")
                             for od in all_dirs)
            if d == ".":
                result.extend(sorted(files))
            elif (len(files) == dir_file_counts.get(d, 0)
                  and len(files) > 1 and not has_subdirs):
                result.append(d + "/*")
            else:
                result.extend(sorted(files))

        # Merge sibling dir/* globs with a common prefix into prefix*/*
        dir_globs = [g for g in result if g.endswith("/*")]
        individual = [g for g in result if not g.endswith("/*")]
        parent_groups = defaultdict(list)
        for g in dir_globs:
            parent = str(Path(g.rstrip("/*")).parent)
            parent_groups[parent].append(g)
        merged_globs = []
        for parent, globs in sorted(parent_groups.items()):
            if len(globs) < 3:
                merged_globs.extend(globs)
                continue
            dir_names = [g.rstrip("/*") for g in globs]
            prefix = os.path.commonprefix(dir_names)
            min_prefix = (parent + "/") if parent != "." else ""
            if len(prefix) > len(min_prefix) + 1:
                merged_globs.append(prefix + "*/*")
            else:
                merged_globs.extend(sorted(globs))
        result = sorted(merged_globs + individual)

        # Deduplicate: if parent/* covers child/*, drop child
        deduped = []
        for g in sorted(result):
            if any(g != prev and fnmatch.fnmatch(g, prev)
                   for prev in deduped):
                continue
            deduped.append(g)
        return deduped

    out = []
    out.append("Format: https://www.debian.org/doc/packaging-manuals/copyright-format/1.0/")
    out.append("Upstream-Name: FIXME")
    out.append("Upstream-Contact: FIXME")
    out.append("Source: FIXME")
    out.append("")

    # Catch-all stanza — only root-level copyrights for the dominant license.
    # If no root-level files have copyright info, use the packager identity.
    merged_cops = merge_copyrights(sorted(root_catchall_cops))
    if not merged_cops:
        _catchall_cop = ""
        if packager_name or packager_email:
            parts = []
            if packager_year:
                parts.append(packager_year)
            if packager_name:
                parts.append(packager_name)
            if packager_email:
                parts.append(f"<{packager_email}>")
            _catchall_cop = " ".join(parts)
        merged_cops = [_catchall_cop] if _catchall_cop else []
    out.append("Files: *")
    out.append("Copyright: " + format_copyright_field(merged_cops))
    out.append("License: " + " AND ".join(biggest_key))
    out.append("")

    # Emit per-author stanzas — each group shares the same license and
    # the same set of copyright holders (regardless of year differences).
    for sk in sorted(stanza_groups,
                     key=lambda k: (k[0], sorted(stanza_groups[k]["paths"])[0])):
        lic_key, _author_fs = sk
        grp = stanza_groups[sk]
        paths = sorted(_filter_debian(grp["paths"]))
        if not paths:
            continue
        cops_raw = sorted(set(grp["cops"]))
        merged_cops = merge_copyrights(cops_raw, file_paths=paths)

        if not merged_cops:
            # No copyright holders detected.  If the license matches the
            # catch-all, these files are already covered by Files: * — no
            # stanza needed.  Otherwise emit a stanza for the differing
            # license with FIXME (user must fill in the real holders).
            if lic_key == biggest_key:
                continue

        globs = smart_glob(paths)

        out.append(format_files_field(globs))
        out.append("Copyright: " + format_copyright_field(merged_cops))
        out.append("License: " + " AND ".join(lic_key))
        out.append("")

    # ── debian/* packaging stanza ─────────────────────────────────
    # For non-native packages, propose a dedicated debian/* stanza with
    # the packager's identity.  Native packages (3.0 (native)) have no
    # upstream/debian split so this stanza is not applicable.
    deb_lic_added = None

    # Interactive prompt (read from /dev/tty since stdout may be piped)
    try:
        _gen_tty = open("/dev/tty", "r")
    except OSError:
        _gen_tty = None

    def gen_ask(prompt):
        if yes_mode:
            sys.stderr.write(prompt + "y (--yes)\n")
            sys.stderr.flush()
            return "y"
        sys.stderr.write(prompt)
        sys.stderr.flush()
        if _gen_tty:
            try:
                return _gen_tty.readline().rstrip("\n")
            except EOFError:
                return ""
        return ""

    if not is_native:
        # Build packager copyright string from detected identity
        packager_cop = ""
        if packager_name or packager_email:
            parts = []
            if packager_year:
                parts.append(packager_year)
            if packager_name:
                parts.append(packager_name)
            if packager_email:
                parts.append(f"<{packager_email}>")
            packager_cop = " ".join(parts)

        deb_lic = "GPL-2+"
        deb_cop = packager_cop or "FIXME"

        print("\n  Proposing debian/* packaging copyright:", file=sys.stderr)
        print(f"  ┌──────────────────────────────────────", file=sys.stderr)
        print(f"  │ Files: debian/*", file=sys.stderr)
        print(f"  │ Copyright: {deb_cop}", file=sys.stderr)
        print(f"  │ License: {deb_lic}", file=sys.stderr)
        print(f"  └──────────────────────────────────────", file=sys.stderr)

        answer = gen_ask("  Accept this stanza? [Y/n/e(dit)] ").strip().lower()
        if answer in ("e", "edit"):
            print("  Enter copyright holder (or press Enter to keep):", file=sys.stderr)
            new_cop = gen_ask(f"    Copyright [{deb_cop}]: ").strip()
            if new_cop:
                deb_cop = new_cop
            print("  Enter license (or press Enter to keep):", file=sys.stderr)
            new_lic = gen_ask(f"    License [{deb_lic}]: ").strip()
            if new_lic:
                deb_lic = new_lic
            answer = "y"

        if answer not in ("n", "no"):
            out.append("Files: debian/*")
            out.append(f"Copyright: {deb_cop}")
            out.append(f"License: {deb_lic}")
            out.append("")
            deb_lic_added = deb_lic
            print("  ✓ debian/* stanza added.", file=sys.stderr)
        else:
            print("  ✗ debian/* stanza skipped.", file=sys.stderr)
    else:
        print("\n  Native package — skipping debian/* stanza.", file=sys.stderr)

    if _gen_tty:
        _gen_tty.close()

    # License text stubs
    all_lics = set()
    all_lics.update(biggest_key)
    for (lic_key, _author_fs) in stanza_groups:
        all_lics.update(lic_key)
    if deb_lic_added:
        all_lics.add(deb_lic_added)

