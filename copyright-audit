# along with this program.  If not, see <https://www.gnu.org/licenses/>.
#
# Uses ScanCode Toolkit (SPDX license database) when available for high-
# accuracy detection, falling back to licensecheck otherwise. Can generate
# a new debian/copyright, check an existing one, or produce a reviewer report.
#
# Usage:
#   copyright-audit [mode] [options] [source-dir]
#
# Modes:
#   check      Validate existing debian/copyright (default)
#   generate   Scan source tree and produce a new debian/copyright on stdout
#   review     Reviewer mode: structured pass/fail report for archive review
#
# Options:
#   -e, --exclude PATTERN   Glob pattern to exclude from scan (repeatable)
#   -o, --output FILE       Write generated copyright to FILE (generate mode)
#   -f, --fix               Interactively fix issues found (check mode only)
#   --yes                   Auto-accept all fixes (use with --fix, no prompts)
#   -v, --verbose           Show all mismatches including likely false positives
#   --export FILE          Export full review findings to FILE (review mode)
#   --no-fetch              Don't download license text from SPDX/CC (use FIXME stubs)
#   -j, --jobs N            Parallel scancode workers (default: nproc)
#   -h, --help              Show this help
#
# Scanner preference (automatic):
#   1. scancode  — SPDX database, highest accuracy (pip install scancode-toolkit)
#   2. licensecheck + decopy — Debian-native tools (apt install licensecheck
#      decopy)
#
# If source-dir is omitted, the current directory is used.
# Requires: python3
# At least one of: scancode-toolkit (pip), licensecheck (apt)

set -euo pipefail

MODE="check"
EXCLUDE_PATTERNS=()
OUTPUT=""
EXPORT=""
VERBOSE=false
FIX_MODE=false
YES_MODE=false
NO_FETCH=false
JOBS=""
SRCDIR=""

show_help() {
    sed -n '2,/^$/{ s/^# //; s/^#$//; p }' "$0"
    exit 0
}

while [[ $# -gt 0 ]]; do
    case "$1" in
        check|generate|review)
            MODE="$1"; shift ;;
        -e|--exclude)
            [[ $# -ge 2 ]] || { echo "Error: $1 requires an argument" >&2; exit 1; }
            EXCLUDE_PATTERNS+=("$2"); shift 2 ;;
        -o|--output)
            [[ $# -ge 2 ]] || { echo "Error: $1 requires an argument" >&2; exit 1; }
            OUTPUT="$2"; shift 2 ;;
        -f|--fix)
            FIX_MODE=true; shift ;;
        --yes)
            YES_MODE=true; shift ;;
        --export)
            [[ $# -ge 2 ]] || { echo "Error: $1 requires an argument" >&2; exit 1; }
            EXPORT="$2"; shift 2 ;;
        -v|--verbose)
            VERBOSE=true; shift ;;
        --no-fetch)
            NO_FETCH=true; shift ;;
        -j|--jobs)
            [[ $# -ge 2 ]] || { echo "Error: $1 requires an argument" >&2; exit 1; }
            JOBS="$2"; shift 2 ;;
        -h|--help)
            show_help ;;
        -*)
            echo "Unknown option: $1" >&2; exit 1 ;;
        *)
            SRCDIR="$1"; shift ;;
    esac
done

SRCDIR="${SRCDIR:-.}"
SRCDIR="$(cd "$SRCDIR" && pwd)"

if [[ "$MODE" != "generate" ]]; then
    COPYRIGHT_FILE="$SRCDIR/debian/copyright"
    if [[ ! -f "$COPYRIGHT_FILE" ]]; then
        echo "Error: $COPYRIGHT_FILE not found." >&2
        echo "  Use 'generate' mode to create one, or run from a debian source tree." >&2
        exit 1
    fi
else
    COPYRIGHT_FILE=""
fi

# ── Detect available scanner ──────────────────────────────────────────
SCANNER=""
if command -v scancode >/dev/null 2>&1; then
    SCANNER="scancode"
elif command -v licensecheck >/dev/null 2>&1; then
    SCANNER="licensecheck"
else
    echo "Error: No license scanner found." >&2
    echo "  Install one of:" >&2
    echo "    pip install scancode-toolkit   (recommended, uses SPDX database)" >&2
    echo "    sudo apt install licensecheck  (basic, Debian-native)" >&2
    exit 1
fi

if ! command -v python3 >/dev/null 2>&1; then
    echo "Error: python3 is required." >&2
    exit 1
fi

_WORKDIR="$(mktemp -d)"
trap 'rm -rf "$_WORKDIR"' EXIT

# ── Default exclusions for VCS / build artifacts ─────────────────────
DEFAULT_EXCLUDES=(".git" ".git/*" ".svn" ".svn/*" ".hg" ".hg/*"
    "node_modules/*" "__pycache__/*"
    ".tox/*" "*.pyc" ".eggs/*" "*.egg-info/*" "_build/*" "build/*")
for _pat in "${DEFAULT_EXCLUDES[@]}"; do
    EXCLUDE_PATTERNS+=("$_pat")
done

# Exclude the copyright file itself (and its .bak) from scanning to
# prevent a feedback loop where declared holders/licenses get re-detected.
if [[ -n "$COPYRIGHT_FILE" ]]; then
    _relcop="${COPYRIGHT_FILE#"$SRCDIR/"}"
    EXCLUDE_PATTERNS+=("$_relcop" "${_relcop}.bak")
fi

echo "=== Debian Copyright Tool ===" >&2
echo "Mode:    $MODE" >&2
echo "Source:  $SRCDIR" >&2
echo "Scanner: $SCANNER" >&2
[[ -n "$COPYRIGHT_FILE" ]] && echo "Copyright: $COPYRIGHT_FILE" >&2
if [[ ${#EXCLUDE_PATTERNS[@]} -gt 0 ]]; then
    echo "Excluding: ${EXCLUDE_PATTERNS[*]}" >&2
fi
echo "" >&2

# ── Run scanner ───────────────────────────────────────────────────────
cd "$SRCDIR"

if [[ "$SCANNER" == "scancode" ]]; then
    echo "Running ScanCode (SPDX database)... this may take several minutes." >&2
    SC_ARGS=(--license --copyright --json "$_WORKDIR/scancode.json")
    if [[ -n "$JOBS" ]]; then
        SC_ARGS+=(-n "$JOBS")
    fi
    # Pass exclude patterns to scancode for early filtering
    for _pat in "${EXCLUDE_PATTERNS[@]}"; do
        SC_ARGS+=(--ignore "$_pat")
    done
    # ScanCode needs a real TTY on stderr for its progress bar.
    # Let stderr go straight to the terminal; capture exit status only.
    scancode "${SC_ARGS[@]}" . && _sc_rc=0 || _sc_rc=$?
    if [[ $_sc_rc -ne 0 ]]; then
        echo "Warning: ScanCode exited with code $_sc_rc. Results may be incomplete." >&2
    fi
    SCAN_FILE="$_WORKDIR/scancode.json"

    # Run licensecheck as a sanity check if available
    if command -v licensecheck >/dev/null 2>&1; then
        echo "Running licensecheck as sanity check..." >&2
        licensecheck -r --deb-machine . 2>/dev/null \
            | sed 's/[\x00-\x08\x0e-\x1f]//g' \
            > "$_WORKDIR/licensecheck_sanity.txt" || true
    fi

    # Run decopy as a sanity check if available and in check/review mode
    if [[ "$MODE" != "generate" ]] && command -v decopy >/dev/null 2>&1 \
       && [[ -n "$COPYRIGHT_FILE" ]]; then
        echo "Running decopy as sanity check..." >&2
        decopy --mode full --copyright-file "$COPYRIGHT_FILE" . \
            > "$_WORKDIR/decopy.txt" || true
    fi
else
    echo "Running licensecheck..." >&2
    if ! licensecheck -r --deb-machine . 2>"$_WORKDIR/licensecheck.err" \
        | sed 's/[\x00-\x08\x0e-\x1f]//g' \
        > "$_WORKDIR/licensecheck.txt"; then
        echo "Warning: licensecheck exited with errors. Results may be incomplete." >&2
        head -20 "$_WORKDIR/licensecheck.err" >&2
    fi
    SCAN_FILE="$_WORKDIR/licensecheck.txt"

    # Also run decopy if available and in check/review mode
    if [[ "$MODE" != "generate" ]] && command -v decopy >/dev/null 2>&1; then
        echo "Running decopy..." >&2
        decopy --mode full --copyright-file "$COPYRIGHT_FILE" . \
            > "$_WORKDIR/decopy.txt" || true
    fi
fi

echo "Analyzing..." >&2
echo "" >&2

# ── Decopy-accelerated generation ─────────────────────────────────────
# If generate mode and decopy is available, let decopy produce the initial
# debian/copyright, then switch to check+fix+yes to harden it with scanner
# cross-validation, DEP-5 normalization, and license text fetching.
DECOPY_GENERATED="false"
if [[ "$MODE" == "generate" ]] && command -v decopy >/dev/null 2>&1; then
    _GEN_TARGET="${OUTPUT:-$_WORKDIR/generated.copyright}"
    if [[ -n "$OUTPUT" ]]; then
        mkdir -p "$(dirname "$OUTPUT")" 2>/dev/null || true
    fi
    echo "Generating initial copyright with decopy..." >&2
    if decopy . > "$_GEN_TARGET" && [[ -s "$_GEN_TARGET" ]]; then
        echo "Hardening with scanner cross-validation and DEP-5 fixes..." >&2
        COPYRIGHT_FILE="$_GEN_TARGET"
        MODE="check"
        FIX_MODE="true"
        YES_MODE="true"
        DECOPY_GENERATED="true"
    else
        echo "decopy produced no output; falling back to built-in generator." >&2
        rm -f "$_GEN_TARGET"
    fi
fi

# ── Pass state to Python ─────────────────────────────────────────────
# ── Resolve symlinks flag for Python ──────────────────────────────────
EXCLUDE_STR="$(printf '%s\n' "${EXCLUDE_PATTERNS[@]+"${EXCLUDE_PATTERNS[@]}"}")"

# ── Detect packager identity ─────────────────────────────────────────
# Priority: DEBFULLNAME/DEBEMAIL > git config > system user
PACKAGER_NAME="${DEBFULLNAME:-}"
PACKAGER_EMAIL="${DEBEMAIL:-}"

if [[ -z "$PACKAGER_NAME" ]]; then
    PACKAGER_NAME="$(git config --get user.name 2>/dev/null || true)"
fi
if [[ -z "$PACKAGER_EMAIL" ]]; then
    PACKAGER_EMAIL="$(git config --get user.email 2>/dev/null || true)"
fi
if [[ -z "$PACKAGER_NAME" ]]; then
    PACKAGER_NAME="$(getent passwd "$USER" 2>/dev/null | cut -d: -f5 | cut -d, -f1 | sed 's/^[[:space:]]*//;s/[[:space:]]*$//' || true)"
fi
if [[ -z "$PACKAGER_NAME" ]]; then
    PACKAGER_NAME="$USER"
fi

PACKAGER_YEAR="$(date +%Y)"
HAS_SANITY_CHECK="false"
if [[ "$SCANNER" == "scancode" && -s "$_WORKDIR/licensecheck_sanity.txt" ]]; then
    HAS_SANITY_CHECK="true"
fi
export EXCLUDE_STR VERBOSE FIX_MODE YES_MODE NO_FETCH SCANNER MODE COPYRIGHT_FILE OUTPUT EXPORT
export PACKAGER_NAME PACKAGER_EMAIL PACKAGER_YEAR HAS_SANITY_CHECK DECOPY_GENERATED

python3 - "$SCAN_FILE" << 'PYEOF'
import datetime, json, os, re, subprocess, sys, fnmatch, textwrap, unicodedata, glob as globmod
import xml.etree.ElementTree as ET
from collections import defaultdict, OrderedDict
from pathlib import Path
from urllib.request import urlopen, Request
from urllib.error import URLError

scan_file = sys.argv[1]
scanner = os.environ.get("SCANNER", "licensecheck")
mode = os.environ.get("MODE", "check")
copyright_file = os.environ.get("COPYRIGHT_FILE", "")
output_file = os.environ.get("OUTPUT", "")
verbose = os.environ.get("VERBOSE", "false") == "true"
fix_mode = os.environ.get("FIX_MODE", "false") == "true"
yes_mode = os.environ.get("YES_MODE", "false") == "true"
no_fetch = os.environ.get("NO_FETCH", "false") == "true"
export_file = os.environ.get("EXPORT", "")
packager_name = os.environ.get("PACKAGER_NAME", "")
packager_email = os.environ.get("PACKAGER_EMAIL", "")
packager_year = os.environ.get("PACKAGER_YEAR", "")
has_sanity_check = os.environ.get("HAS_SANITY_CHECK", "false") == "true"
_decopy_generated = os.environ.get("DECOPY_GENERATED", "false") == "true"

# ── Detect native Debian packages ─────────────────────────────────────
# Native packages ("3.0 (native)") have no upstream/debian split, so a
# separate Files: debian/* stanza is inappropriate.
def _is_native_package():
    try:
        fmt = Path("debian/source/format").read_text(encoding="utf-8").strip()
        return fmt == "3.0 (native)"
    except (OSError, UnicodeDecodeError):
        return False

is_native = _is_native_package()

# ══════════════════════════════════════════════════════════════════════
# Built-in license texts for non-SPDX licenses
# ══════════════════════════════════════════════════════════════════════
_BUILTIN_LICENSE_TEXTS = {
    "Unsplash": (
        "Unsplash License\n"
        "\n"
        "Unsplash grants you an irrevocable, nonexclusive, worldwide copyright\n"
        "license to download, copy, modify, distribute, perform, and use images\n"
        "from Unsplash for free, including for commercial purposes, without\n"
        "permission from or attributing the photographer or Unsplash. This\n"
        "license does not include the right to compile images from Unsplash to\n"
        "replicate a similar or competing service.\n"
        "\n"
        "https://unsplash.com/license"
    ),
}

# ══════════════════════════════════════════════════════════════════════
# License text fetcher — downloads from SPDX or Creative Commons
# ══════════════════════════════════════════════════════════════════════
_license_text_cache = {}

def fetch_license_text(license_id):
    """Fetch full license text from built-in texts, SPDX, or Creative Commons.

    Returns the license text as a string, or None if unavailable.
    Results are cached so each license is fetched at most once.
    """
    # Built-in texts are always available regardless of --no-fetch
    if license_id in _BUILTIN_LICENSE_TEXTS:
        return _BUILTIN_LICENSE_TEXTS[license_id]

    if no_fetch:
        return None
    if license_id in _license_text_cache:
        return _license_text_cache[license_id]

    text = None

    # Try Creative Commons URL first for CC licenses
    if license_id.upper().startswith("CC-") and license_id.upper() != "CC0-1.0":
        text = _fetch_cc_text(license_id)

    # Try SPDX for everything (including CC as fallback)
    if text is None:
        text = _fetch_spdx_text(license_id)

    _license_text_cache[license_id] = text
    return text

def _fetch_cc_text(license_id):
    """Fetch CC license text from creativecommons.org."""
    tag = license_id.lower().replace("cc-", "").rsplit("-", 1)
    variant = tag[0] if tag else license_id.lower()
    version = tag[1] if len(tag) > 1 else "4.0"
    url = f"https://creativecommons.org/licenses/{variant}/{version}/legalcode.txt"
    return _fetch_url(url)

# Reverse mapping from DEP-5 names back to SPDX identifiers for API lookups
_DEP5_TO_SPDX = {
    "Expat": "MIT",
    "Artistic": "Artistic-1.0",
    "GPL-1": "GPL-1.0-only", "GPL-1+": "GPL-1.0-or-later",
    "GPL-2": "GPL-2.0-only", "GPL-2+": "GPL-2.0-or-later",
    "GPL-3": "GPL-3.0-only", "GPL-3+": "GPL-3.0-or-later",
    "LGPL-2": "LGPL-2.0-only", "LGPL-2+": "LGPL-2.0-or-later",
    "LGPL-2.1": "LGPL-2.1-only", "LGPL-2.1+": "LGPL-2.1-or-later",
    "LGPL-3": "LGPL-3.0-only", "LGPL-3+": "LGPL-3.0-or-later",
    "AGPL-3": "AGPL-3.0-only", "AGPL-3+": "AGPL-3.0-or-later",
    "GFDL": "GFDL-1.3-only",
    "GFDL-1.1": "GFDL-1.1-only", "GFDL-1.1+": "GFDL-1.1-or-later",
    "GFDL-1.2": "GFDL-1.2-only", "GFDL-1.2+": "GFDL-1.2-or-later",
    "GFDL-1.3": "GFDL-1.3-only", "GFDL-1.3+": "GFDL-1.3-or-later",
}

def _fetch_spdx_text(license_id):
    """Fetch license text from the SPDX license list API."""
    # Map DEP-5 names back to SPDX identifiers for the API
    spdx_id = _DEP5_TO_SPDX.get(license_id, license_id)
    url = f"https://spdx.org/licenses/{spdx_id}.json"
    body = _fetch_url(url)
    if body is None:
        return None
    try:
        data = json.loads(body)
        return data.get("licenseText", None)
    except (json.JSONDecodeError, KeyError):
        return None

def _fetch_url(url, timeout=15):
    """GET a URL and return the body text, or None on failure."""
    try:
        req = Request(url, headers={"User-Agent": "copyright-audit/1.0"})
        with urlopen(req, timeout=timeout) as resp:
            return resp.read().decode("utf-8", errors="replace")
    except (URLError, OSError, ValueError):
        return None

def format_license_body(text, max_col=80):
    """Format fetched license text for DEP-5 (indent each line with a space).
    Word-wraps lines that would exceed max_col."""
    body_width = max_col - 1  # 1-space DEP-5 indent leaves this much for content
    lines = []
    for line in text.splitlines():
        if line.strip() == "":
            lines.append(" .")
        elif len(line) <= body_width:
            lines.append(" " + line)
        else:
            stripped = line.lstrip()
            leading = line[:len(line) - len(stripped)]
            avail = body_width - len(leading)
            if avail < 20:
                lines.append(" " + line)
            else:
                wrapped = textwrap.wrap(
                    stripped, width=avail,
                    break_long_words=False, break_on_hyphens=False)
                for wl in (wrapped or [stripped]):
                    lines.append(" " + leading + wl)
    return "\n".join(lines)

exclude_raw = os.environ.get("EXCLUDE_STR", "").strip()
excludes = [p for p in exclude_raw.split("\n") if p]

def is_excluded(filepath):
    fp = filepath.lstrip("./")
    # Always exclude VCS internals even if not in the exclude list
    if fp == ".git" or fp.startswith(".git/"):
        return True
    return any(fnmatch.fnmatch(fp, pat) for pat in excludes)

# Patterns for metadata/infrastructure files that should be covered by
# the Files: * catch-all rather than receiving their own stanzas.
_METADATA_GLOBS = (
    "*/metadata.json",
    "*/metadata.desktop",
    "*/contents/screenshot.png",
    "usr/share/gnome-background-properties/*",
    "usr/share/plymouth/themes/*/*.plymouth",
    "etc/*",
    "po/*",
)
_METADATA_BASENAMES = frozenset({
    "AUTHORS", "COPYING", "COPYING.txt", "NEWS", "README", "README.md",
    "ChangeLog", "POTFILES.in",
})

def is_metadata_file(filepath):
    """Return True if *filepath* is a metadata or infrastructure file
    that should be covered by the Files: * catch-all stanza rather than
    getting its own per-file stanza.  These include KDE metadata.json,
    wallpaper screenshot.png thumbnails, GNOME XML descriptors, packaging
    boilerplate, configuration files, and translation catalogs."""
    fp = filepath.lstrip("./")
    if os.path.basename(fp) in _METADATA_BASENAMES:
        return True
    # Symlinks are never the canonical copyright target
    if os.path.islink(fp):
        return True
    return any(fnmatch.fnmatch(fp, pat) for pat in _METADATA_GLOBS)

