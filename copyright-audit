# Stanza consolidation detection
# ══════════════════════════════════════════════════════════════════════

def _parse_paragraph_stanzas(text):
    """Parse copyright text into paragraph-level stanzas.

    Returns list of dicts:
    [{"files": [str], "cops": [str], "license": str,
      "comment": str or None, "para_text": str}]
    Only includes paragraphs that have Files:, Copyright:, and License:.
    """
    result = []
    for para in text.split("\n\n"):
        files = []
        cops = []
        lic = None
        comment_lines = []
        current_field = None
        for line in para.split("\n"):
            if line.startswith("Files:"):
                rest = line[6:].strip()
                if rest:
                    files.extend(rest.split())
                current_field = "files"
            elif line.startswith("Copyright:"):
                cop_val = line[10:].strip()
                if cop_val:
                    cops.append(cop_val)
                current_field = "copyright"
            elif line.startswith("License:"):
                lic = line[8:].strip().split()[0] if line[8:].strip() else None
                current_field = "license"
            elif line.startswith("Comment:"):
                comment_lines.append(line[8:].strip())
                current_field = "comment"
            elif current_field == "files" and line.startswith(" ") and not line.startswith(" ."):
                files.extend(line.strip().split())
            elif current_field == "copyright" and line.startswith(" ") and line.strip():
                cops.append(line.strip())
            elif current_field == "comment" and line.startswith(" "):
                comment_lines.append(line[1:] if line.startswith(" ") else line)
        comment = "\n".join(comment_lines) if comment_lines else None
        if files and lic and cops:
            result.append({
                "files": files,
                "cops": cops,
                "license": lic,
                "comment": comment,
                "para_text": para,
            })
    return result

def check_consolidation(text=None):
    """Identify file stanzas that share the same license and author(s).

    Stanzas with identical (license, normalized copyright holder set) can
    be merged into a single stanza with all files listed and copyright
    years collapsed into ranges.

    Returns list of consolidation groups:
    [{"license": str, "stanzas": [dict], "merged_files": [str],
      "merged_cops": [str]}]
    Each group contains 2+ stanzas that could be consolidated.
    """
    src = text if text is not None else copyright_text
    para_stanzas = _parse_paragraph_stanzas(src)

    # Group by (license, normalized holders set)
    groups = defaultdict(list)
    for ps in para_stanzas:
        # Skip catch-all stanzas
        if ps["files"] == ["*"]:
            continue
        # Never consolidate stanzas that have Comment fields — they
        # carry per-file attribution (provenance URLs, etc.) that
        # would be lost in a merge.
        if ps.get("comment"):
            continue
        holder_keys = []
        for c in ps["cops"]:
            n = norm_copyright(c)
            if n:
                holder_keys.append(n)
        holder_key = frozenset(holder_keys)
        groups[(ps["license"], holder_key)].append(ps)

    # Return only groups with 2+ stanzas
    consolidatable = []
    for (lic, holder_key), stanza_list in sorted(groups.items()):
        if len(stanza_list) >= 2:
            # Merge files from all stanzas
            merged_files = []
            for ps in stanza_list:
                merged_files.extend(ps["files"])
            # Merge copyright lines (combine years per author)
            all_cops = []
            for ps in stanza_list:
                all_cops.extend(ps["cops"])
            merged_cops = merge_copyrights(all_cops, file_paths=merged_files)
            consolidatable.append({
                "license": lic,
                "stanzas": stanza_list,
                "merged_files": merged_files,
                "merged_cops": merged_cops,
            })
    return consolidatable

def _simplify_file_list(paths, all_dir_counts=None):
    """Reduce a list of file paths using glob patterns where possible.

    For each directory, if the stanza owns ALL files in that directory,
    represent them as dir/*.  If *all_dir_counts* is provided (a dict
    mapping directory → total file count across ALL stanzas), dir/* is
    only used when the stanza's files in that directory equal the total.
    This prevents a stanza for one author from claiming dir/* when other
    authors also have files in the same directory.
    """
    dirs = defaultdict(list)
    for p in paths:
        d = str(Path(p).parent)
        dirs[d].append(p)

    all_dirs = set(dirs.keys())

    # Phase 1: collapse leaf directories where we have 2+ files.
    # Skip directories that have sub-directories in the file list
    # (dir/* in DEP-5 matches recursively).
    # Only use dir/* when the stanza owns ALL files in the directory.
    phase1 = []
    for d, files in sorted(dirs.items()):
        has_subdirs = any(od != d and od.startswith(d + "/")
                         for od in all_dirs)
        owns_all = True
        if all_dir_counts and d in all_dir_counts:
            owns_all = len(files) >= all_dir_counts[d]
        if d == "." or len(files) < 2 or has_subdirs or not owns_all:
            phase1.extend(sorted(files))
        else:
            phase1.append(d + "/*")

    # Phase 2: merge sibling dir/* globs that share a common prefix.
    # e.g. src/FooA/*, src/FooB/*, src/FooC/* → src/Foo*/*
    dir_globs = [g for g in phase1 if g.endswith("/*")]
    individual = [g for g in phase1 if not g.endswith("/*")]

    # Group dir/* globs by parent directory
    parent_groups = defaultdict(list)
    for g in dir_globs:
        parent = str(Path(g.rstrip("/*")).parent)
        parent_groups[parent].append(g)

    merged_globs = []
    for parent, globs in sorted(parent_groups.items()):
        if len(globs) < 2:
            merged_globs.extend(globs)
            continue
        # Find longest common prefix of the directory names
        dir_names = [g.rstrip("/*") for g in globs]
        prefix = os.path.commonprefix(dir_names)
        # prefix must end at a meaningful boundary and be longer than
        # just the parent dir + separator
        min_prefix = parent + "/" if parent != "." else ""
        if len(prefix) > len(min_prefix) + 1:
            # Check the proposed glob covers only the intended dirs
            pattern = prefix + "*/*"
            # Verify it doesn't accidentally match individual files
            # that are not part of any dir/* glob in this group
            merged_globs.append(pattern)
        else:
            merged_globs.extend(sorted(globs))

    result = sorted(merged_globs + individual)

    # Deduplicate: if parent/* or parent*/* covers a more specific glob
    deduped = []
    for g in result:
        if any(g != prev and fnmatch.fnmatch(g, prev)
               for prev in deduped):
            continue
        deduped.append(g)
    return deduped

# ══════════════════════════════════════════════════════════════════════
# False-positive heuristic
# ══════════════════════════════════════════════════════════════════════
def classify_fp(filepath, detected, declared):
    fp = filepath.lstrip("./")
    if re.search(r'(?:^|/)LICENSE[^/]*\.txt$', fp, re.I):
        return "license-text-file"
    if re.search(r'conftools/|\.m4$|config\.guess$|config\.sub$|ltmain', fp, re.I):
        return "autoconf-boilerplate"
    if fp.endswith(".rst") and detected.lower() in (
            "cecill", "cecill-c", "bsl-1.0", "apache-2.0", "gpl-2"):
        return "doc-embeds-plugin-license"
    if re.search(r'(CMakeLists\.txt|\.pro)$', fp):
        return "project-build-file"
    if fp.startswith("tools/"):
        return "tools-infrastructure"
    if is_metadata_file(filepath):
        return "metadata-infrastructure"
    return None

def licenses_compatible(detected_raw, declared):
    """Check if a detected license is compatible with what's declared.

    Handles the full GPL/LGPL/AGPL family, BSD/MIT aliases,
    and 'or-later' subsumption rules.
    """
    dn = norm_cmp(declared)
    dn2 = norm_cmp(detected_raw)
    if dn == dn2:
        return True

    # "or-later" (+) declared subsumes the base version and higher
    # e.g. GPL-2+ declared covers GPL-2, GPL-3, GPL-3+ detected
    GPL_VERSIONS = {
        "gpl-1": 1, "gpl-1+": 1, "gpl-2": 2, "gpl-2+": 2,
        "gpl-3": 3, "gpl-3+": 3, "gpl": 2,
    }
    LGPL_VERSIONS = {
        "lgpl-2": 2.0, "lgpl-2+": 2.0, "lgpl-2.1": 2.1, "lgpl-2.1+": 2.1,
        "lgpl-3": 3.0, "lgpl-3+": 3.0,
    }
    AGPL_VERSIONS = {
        "agpl-1": 1, "agpl-1+": 1,
        "agpl-3": 3, "agpl-3+": 3,
    }
    GFDL_VERSIONS = {
        "gfdl-1.1": 1.1, "gfdl-1.1+": 1.1,
        "gfdl-1.2": 1.2, "gfdl-1.2+": 1.2,
        "gfdl-1.3": 1.3, "gfdl-1.3+": 1.3,
    }

    for family_map in (GPL_VERSIONS, LGPL_VERSIONS, AGPL_VERSIONS, GFDL_VERSIONS):
        dv = family_map.get(dn)
        d2v = family_map.get(dn2)
        if dv is not None and d2v is not None:
            is_plus_declared = dn.endswith("+")
            is_plus_detected = dn2.endswith("+")
            # Exact family match
            if dv == d2v:
                # GPL-2+ declared covers GPL-2 detected (and vice versa if
                # the declared is at least as permissive)
                if is_plus_declared:
                    return True
                if not is_plus_detected:
                    return True  # both are -only, same version
            # or-later declared covers higher versions
            if is_plus_declared and d2v >= dv:
                return True
            # Don't flag or-later detected against a higher -only declared
            # e.g. GPL-2+ detected, GPL-3 declared  (could be exercised as GPL-3)
            if is_plus_detected and dv >= d2v:
                return True
            break  # Same family, versions don't match

    # BSD family: BSD-2-Clause and BSD-3-Clause are often interchangeable
    # in practice (scanner may detect one, copyright declares the other)
    bsd_set = {"bsd-2-clause", "bsd-3-clause", "bsd"}
    if dn in bsd_set and dn2 in bsd_set:
        return True

    # MPL-2.0 with secondary license exception is compatible with GPL
    if "mpl-2" in dn2 and "gpl" in dn:
        return True

    # LGPL code can be distributed under GPL (LGPL Section 3 / LGPL-2.1 §3).
    # LGPL-2+ → GPL-2+, LGPL-2.1+ → GPL-2+, LGPL-3 → GPL-3+, etc.
    # LGPL-2.1 maps to GPL-2 (not 2.1), so compare with int(lgpl_v).
    if dn2 in LGPL_VERSIONS and dn in GPL_VERSIONS:
        lgpl_v = LGPL_VERSIONS[dn2]
        gpl_v = GPL_VERSIONS[dn]
        gpl_min = int(lgpl_v)  # LGPL-2.1 → GPL-2, LGPL-3 → GPL-3
        is_plus_declared = dn.endswith("+")
        if is_plus_declared and gpl_v >= gpl_min:
            return True
        if not is_plus_declared and gpl_v >= gpl_min:
            return True

    # Expat / MIT are equivalent
    expat_set = {"expat", "mit"}
    if dn in expat_set and dn2 in expat_set:
        return True

    return False

# Non-free / non-DFSG licenses that warrant a warning.
# Note: AGPL-3 and CeCILL-2.1 are DFSG-free; they are NOT listed here.
_NONFREE_RAW = {
    "sspl-1.0",           # Server Side Public License
    "busl-1.1",           # Business Source License (MariaDB, HashiCorp, etc.)
    "commons-clause",     # Commons Clause (added to otherwise open licenses)
    "elastic-2.0",        # Elastic License 2.0
    "json",               # JSON License ("Good, not Evil" — non-free per Debian)
    "rsal-2.0",           # Redis Source Available License
    "polyform-noncommercial-1.0.0",  # PolyForm Noncommercial
    "polyform-small-business-1.0.0", # PolyForm Small Business
    "polyform-shield-1.0.0",         # PolyForm Shield
    "hippocratic-2.1",    # Hippocratic License (ethical use restriction)
    "confluent-community-1.0",  # Confluent Community License
    "apsl-1.0",           # Apple PSL 1.0 (non-free per FSF)
    "apsl-1.1",           # Apple PSL 1.1 (non-free per FSF)
    "watcom-1.0",         # Sybase Open Watcom (choice-of-venue / publish-changes)
}
NONFREE = {norm_cmp(x) for x in _NONFREE_RAW}

# CC-NC (NonCommercial) and CC-ND (NoDerivatives) are non-free per DFSG.
# CC-BY and CC-BY-SA (without NC/ND) are DFSG-free and NOT listed here.
def is_nonfree(license_id):
    """Check if a license is non-free (DFSG-incompatible)."""
    n = norm_cmp(license_id)
    if n in NONFREE:
        return True
    # CC licenses with NC or ND restrictions (with or without version)
    n_lower = n.lower()
    if "cc-by-nc" in n_lower or "cc-by-nd" in n_lower:
        return True
    return False

