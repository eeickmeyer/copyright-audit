    else:
        print(f"\n  RESULT: {total_issues} item(s) may need attention.")
    print()

    # Offer to enter fix mode if issues were found and --fix wasn't given
    fixable_dep5_count = sum(1 for i in dep5_issues if i[3] is not None)
    has_fixable = total_issues > 0 or fixable_dep5_count > 0 or consol_saving > 0
    if not fix_mode and has_fixable and copyright_file:
        if yes_mode:
            fix_mode = True
        elif sys.stderr.isatty():
            try:
                _offer_tty = open("/dev/tty", "r")
                sys.stderr.write("  Run interactive fix mode now? [y/N/A(yes to all)] ")
                sys.stderr.flush()
                offer_ans = _offer_tty.readline().rstrip("\n").strip().lower()
                _offer_tty.close()
                if offer_ans in ("y", "yes"):
                    fix_mode = True
                elif offer_ans in ("a", "all"):
