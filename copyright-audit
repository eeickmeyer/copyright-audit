# Helper: warn about unresolved stubs in written output
# ══════════════════════════════════════════════════════════════════════
def _warn_stubs(text, dest):
    """Print a loud warning if the output contains unresolved FIXME/TODO stubs."""
    stub_re = re.compile(r'\b(FIXME|TODO|PLACEHOLDER)\b', re.IGNORECASE)
    stub_lines = [(i + 1, ln) for i, ln in enumerate(text.splitlines())
                  if stub_re.search(ln)]
    if not stub_lines:
        return
    bar = "!" * 60
    print(f"\n{bar}", file=sys.stderr)
    print(f"  WARNING: {len(stub_lines)} unresolved stub(s) in {dest}",
          file=sys.stderr)
    print(bar, file=sys.stderr)
    for lineno, ln in stub_lines:
        print(f"  Line {lineno:4d}: {ln.strip()}", file=sys.stderr)
    print(f"{bar}\n", file=sys.stderr)

